<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiriha.ViewModels"
             xmlns:vmAnalytics="using:Kiriha.ViewModels.Analytics"
             xmlns:vmAnimeDetails="using:Kiriha.ViewModels.AnimeDetails"
             xmlns:vmAnimeList="using:Kiriha.ViewModels.AnimeList"
             xmlns:vmHistory="using:Kiriha.ViewModels.History"
             xmlns:vmPlayer="using:Kiriha.ViewModels.Player"
             xmlns:vmSeasonal="using:Kiriha.ViewModels.Seasonal"
             xmlns:vmSettings="using:Kiriha.ViewModels.Settings"
             xmlns:vmTorrents="using:Kiriha.ViewModels.Torrents"
             xmlns:vmSearch="using:Kiriha.ViewModels.Search"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:views="using:Kiriha.Views"
        xmlns:controls="using:Kiriha.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="Kiriha.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title=""
        TransparencyLevelHint="Mica, AcrylicBlur"
        TransparencyBackgroundFallback="Transparent"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="34"
        WindowDecorations="BorderOnly"
        Padding="0"
        Icon="avares://Kiriha/Assets/kiriha.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- ═══════════════ Global Styles ═══════════════ -->
    <Window.Styles>
        <!-- Nav items: pill-shape, left-rounded -->
        <Style Selector="ListBox.NavList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,1,6,1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ListBox.NavList ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource NavItemHoverColor}"/>
        </Style>

        <Style Selector="ListBox.NavList ListBoxItem material|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>

        <Style Selector="ListBox.NavList ListBoxItem:selected material|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
        </Style>

        <Style Selector="ListBox.NavList ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavItemHoverColor}"/>
        </Style>

        <!-- Selection pill indicator -->
        <Style Selector="ListBox.NavList ListBoxItem Border.SelectionIndicator">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected Border.SelectionIndicator">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- Active class for Settings (non-ListBox) -->
        <Style Selector="material|MaterialIcon.active">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        </Style>
        <Style Selector="TextBlock.active">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="F9" Command="{Binding TestPlayerCommand}" />
    </Window.KeyBindings>

    <LayoutTransformControl Name="ScaleRoot">
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </LayoutTransformControl.LayoutTransform>
        <Grid RowDefinitions="34, *" Background="{x:Null}"
              PointerPressed="OnTitleBarPressed">
            <!-- ═══ TitleBar (drag area) ═══
                 ExtendClientAreaToDecorationsHint=True hides the OS chrome, so we
                 have to drive Begin{Move,Resize}Drag ourselves on the top 34px.
                 Handler lives on the root Grid: child controls that consume their
                 own click (Button, ListBoxItem, …) set Handled=true and the drag
                 never fires for them; clicks on empty title-bar area bubble up
                 unhandled and trigger the move. -->
    
            <!-- Custom Caption Buttons (replaces buggy system chrome) -->
            <controls:TitleBarButtons Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" ZIndex="999"/>
    
            <SplitView Grid.Row="0" Grid.RowSpan="2" IsPaneOpen="{Binding IsPaneOpen}"
                   DisplayMode="CompactInline"
                   CompactPaneLength="60"
                   OpenPaneLength="230"
                   Background="Transparent"
                   PaneBackground="{DynamicResource LayerFillColorDefault}">

            <!-- ═══════════════ Navigation Pane ═══════════════ -->
            <SplitView.Pane>
                <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

                    <!-- Brand header — лейаут одинаковый в обоих режимах,
                         текст просто "проявляется" справа при раскрытии панели. -->
                    <Button Grid.Row="0"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            Margin="0,10,0,6"
                            Command="{Binding NavigateWelcomeCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    VerticalAlignment="Center"
                                    Margin="2,0,0,0">
                            <controls:LeafLogo Width="56" Height="56"
                                               ShowHalo="False"
                                               VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource l.common.app_name}"
                                       FontSize="22" FontWeight="Light"
                                       LetterSpacing="3"
                                       VerticalAlignment="Center"
                                       Opacity="0.9"
                                       IsVisible="{Binding IsPaneOpen}"/>
                        </StackPanel>
                    </Button>

                    <!-- Divider -->
                    <Border Grid.Row="1" Height="1"
                            Background="{DynamicResource DividerStrokeColorDefault}"
                            Margin="12,0,12,0"
                            Opacity="0.6"/>

                    <!-- Section label -->
                    <Panel Grid.Row="2" Height="28">
                        <TextBlock Text="{DynamicResource l.navigation.header}" FontSize="10" FontWeight="Bold" LetterSpacing="1.2"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                                   Margin="18,12,0,0" IsVisible="{Binding IsPaneOpen}"/>
                    </Panel>

                    <!-- Navigation items -->
                    <ListBox Grid.Row="3" Background="Transparent" BorderThickness="0"
                             Classes="NavList"
                             IsEnabled="{Binding !IsNavigationBlocked}"
                             SelectedIndex="{Binding SelectedNavigationIndex}">

                        <!-- Profile -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="AccountCircleOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.profile}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- Home / Now Playing -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="PlayCircleOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.now_playing}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- Anime List -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="FormatListBulleted" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.anime_list}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- Seasonal -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="CalendarMonthOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.seasonal}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- History -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="History" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.history}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- Torrents -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="CloudDownloadOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.torrents}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>

                        <!-- Search / Discover -->
                        <ListBoxItem>
                            <Panel Height="40">
                                <Border Classes="SelectionIndicator" Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="Magnify" Width="22" Height="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource l.navigation.search}" FontSize="13" VerticalAlignment="Center"
                                               IsVisible="{Binding IsPaneOpen}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Panel>
                        </ListBoxItem>
                    </ListBox>

                    <!-- ═══ Bottom controls ═══ -->
                    <StackPanel Grid.Row="4" Margin="6,0,6,12" Spacing="2">
                        <Border Height="1" Background="{DynamicResource DividerStrokeColorDefault}" Margin="6,0,6,6"/>

                        <!-- Settings -->
                        <Button Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" CornerRadius="6"
                                Padding="0" Height="40"
                                IsEnabled="{Binding !IsNavigationBlocked}"
                                Command="{Binding NavigateSettings}">
                            <Panel>
                                <Border Width="3" Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Left" CornerRadius="0,3,3,0" Height="18"
                                        IsVisible="{Binding IsSettingsSelected}"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                    <material:MaterialIcon Kind="CogOutline" Width="22" Height="22" VerticalAlignment="Center"
                                                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                          Classes.active="{Binding IsSettingsSelected}"/>
                                    <TextBlock Text="{DynamicResource l.navigation.settings}" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               IsVisible="{Binding IsPaneOpen}"
                                               Classes.active="{Binding IsSettingsSelected}"/>
                                </StackPanel>
                            </Panel>
                        </Button>

                        <!-- Collapse toggle -->
                        <Button Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" CornerRadius="6"
                                Padding="0" Height="36"
                                Command="{Binding TriggerPaneCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="14" Margin="14,0,0,0">
                                <Panel Width="22" Height="22" VerticalAlignment="Center">
                                    <material:MaterialIcon Kind="ChevronDoubleLeft" Width="20" Height="20"
                                                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" IsVisible="{Binding IsPaneOpen}"/>
                                    <material:MaterialIcon Kind="ChevronDoubleRight" Width="20" Height="20"
                                                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" IsVisible="{Binding !IsPaneOpen}"/>
                                </Panel>
                                <TextBlock Text="{DynamicResource l.common.actions.collapse}" FontSize="11" 
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center" IsVisible="{Binding IsPaneOpen}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <!-- ═══════════════ Main Content ═══════════════ -->
            <SplitView.Content>
                <Grid>
                    <Border Background="{DynamicResource ContentSurfaceFill}"
                            CornerRadius="0"
                            Padding="0,30,0,0"
                            Margin="0,0,0,0"
                            BorderBrush="{DynamicResource CardStrokeColorDefault}"
                            BorderThickness="1,0,0,0">
                        <TransitioningContentControl Content="{Binding CurrentPage}" />
                    </Border>
                    
                </Grid>
            </SplitView.Content>
        </SplitView>

        <!-- ═══════════════ Settings Modal Overlay (Discord-style) ═══════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding IsSettingsOpen}"
                Background="#80000000"
                ZIndex="100">
            <Border.Styles>
                <!-- Dim-overlay button must never show hover/pressed visuals -->
                <Style Selector="Button.DimOverlay">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </Border.Styles>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Border.Transitions>

            <Grid>
                <!-- Click dim to close -->
                <Button Classes="DimOverlay"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Focusable="False"
                        Command="{Binding CloseSettingsCommand}"/>

                <!-- Modal card -->
                <Border Name="SettingsModalCard"
                        Background="{DynamicResource ModalBackgroundFill}"
                        CornerRadius="12"
                        Margin="40,50,40,50"
                        MaxWidth="1280" MaxHeight="820"
                        BorderBrush="{DynamicResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        BoxShadow="0 10 40 0 #60000000"
                        ClipToBounds="True">
                    <Grid>
                        <ContentControl Content="{Binding SettingsViewModel}"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

                        <!-- Close (X) top-right -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,16,16,0"
                                Width="32" Height="32"
                                Padding="0"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="16"
                                Command="{Binding CloseSettingsCommand}"
                                ToolTip.Tip="Esc">
                            <material:MaterialIcon Kind="Close" Width="18" Height="18"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ Update Dialog Overlay ═══════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding IsUpdateDialogOpen}"
                Background="#80000000"
                ZIndex="110">
            <Border.Styles>
                <Style Selector="Button.DimOverlay">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </Border.Styles>

            <Grid>
                <!-- Click dim to close (disabled when downloading/downloaded) -->
                <Button Classes="DimOverlay"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Focusable="False"
                        IsEnabled="{Binding !UpdateDialog.IsDownloadingOrFinished, FallbackValue=True}"
                        Command="{Binding CloseUpdateDialogCommand}"/>

                <!-- Modal card -->
                <Border Background="{DynamicResource ModalBackgroundFill}"
                        CornerRadius="12"
                        Width="480" Height="280"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="{DynamicResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        BoxShadow="0 10 40 0 #60000000"
                        ClipToBounds="True">
                    <ContentControl Content="{Binding UpdateDialog}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </LayoutTransformControl>
</Window>
