<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiriha.ViewModels"
             xmlns:vmAnalytics="using:Kiriha.ViewModels.Analytics"
             xmlns:vmAnimeDetails="using:Kiriha.ViewModels.AnimeDetails"
             xmlns:vmAnimeList="using:Kiriha.ViewModels.AnimeList"
             xmlns:vmHistory="using:Kiriha.ViewModels.History"
             xmlns:vmPlayer="using:Kiriha.ViewModels.Player"
             xmlns:vmSeasonal="using:Kiriha.ViewModels.Seasonal"
             xmlns:vmSettings="using:Kiriha.ViewModels.Settings"
             xmlns:vmTorrents="using:Kiriha.ViewModels.Torrents"
             xmlns:vmSearch="using:Kiriha.ViewModels.Search"
             xmlns:models="using:Kiriha.Models"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:conv="using:Kiriha.Views.Converters"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="Kiriha.Views.SearchView"
             x:DataType="vmSearch:SearchViewModel">

    <UserControl.Resources>
        <conv:LocConverter x:Key="LocConverter"/>
        <conv:AdultColorConverter x:Key="AdultColorConverter"/>
        <conv:AdultIconConverter x:Key="AdultIconConverter"/>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <conv:StatusNotNoneConverter x:Key="StatusNotNoneConverter"/>
        <conv:StatusNoneConverter x:Key="StatusNoneConverter"/>
        
        <!-- Result Card Template (List View) -->
        <DataTemplate x:Key="SearchResultTemplate" x:DataType="models:AnimeItem">
            <Border Background="{DynamicResource CardBackgroundFillDefault}"
                    CornerRadius="12" ClipToBounds="True"
                    BorderBrush="{DynamicResource CardStrokeColorDefault}" BorderThickness="1"
                    BoxShadow="0 1 3 0 #06000000"
                    HorizontalAlignment="Stretch"
                    DoubleTapped="Poster_DoubleTapped">
                <Grid ColumnDefinitions="110, *">
                    <!-- Left: Poster -->
                    <Panel Grid.Column="0">
                        <asyncImageLoader:AdvancedImage Source="{Binding MainPictureUrl}" Stretch="UniformToFill" Height="150" />
                        
                        <!-- Score overlay on poster -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Right" 
                                Background="#CC000000" CornerRadius="0,0,0,8" Padding="5,3">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <material:MaterialIcon Kind="Star" Width="10" Height="10" Foreground="Gold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MeanScore}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Panel>

                    <!-- Right: Content -->
                    <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Margin="14,10,14,10">
                        
                        <!-- Top: Titles & Action Buttons -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" Spacing="1" Margin="0,0,12,0">
                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" 
                                           MaxLines="1" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" 
                                           Foreground="{DynamicResource SystemBaseHighColor}"/>
                                <TextBlock Text="{Binding RussianTitle}" FontSize="12" FontWeight="Medium"
                                           MaxLines="1" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource SystemAccentColor}"
                                           IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                           
                                <!-- Meta Info (Type, Episodes, Year) -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Type, Converter={StaticResource LocConverter}}" FontSize="10" FontWeight="Bold" Opacity="0.9"/>
                                    </Border>
                                    <!-- Episodes Card -->
                                    <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="4" Padding="6,2"
                                            IsVisible="{Binding TotalEpisodes, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="{Binding TotalEpisodes}" FontSize="10" FontWeight="Bold" Opacity="0.9"/>
                                            <TextBlock Text="{DynamicResource l.history.unit_ep}" FontSize="10" FontWeight="Bold" Opacity="0.9"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="4" Padding="6,2"
                                            IsVisible="{Binding Season, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding Season, Converter={StaticResource LocConverter}}" FontSize="10" FontWeight="Bold" Opacity="0.9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Buttons (Icon + Text) -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top"
                                        IsVisible="{Binding Status, Converter={StaticResource StatusNoneConverter}}">
                                <Button Command="{Binding $parent[UserControl].DataContext.AddToWatchingCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="6" Padding="10,6"
                                        BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefault}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <material:MaterialIcon Kind="EyeOutline" Width="16" Height="16" Foreground="{DynamicResource SystemAccentColor}"/>
                                        <TextBlock Text="{DynamicResource l.anime.status.watching}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource SystemAccentColor}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding $parent[UserControl].DataContext.AddToPlanToWatchCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="6" Padding="10,6"
                                        BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefault}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <material:MaterialIcon Kind="CalendarClock" Width="16" Height="16" Foreground="#1565C0"/>
                                        <TextBlock Text="{DynamicResource l.anime.status.plan_to_watch}" FontSize="12" FontWeight="Medium" Foreground="#1565C0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Middle: Synopsis (Compacted) -->
                        <TextBlock Grid.Row="1" Text="{Binding Presentation.DisplaySynopsis}" FontSize="12" Opacity="0.6"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,8,0,8" MaxLines="2"
                                   VerticalAlignment="Top"/>

                        <!-- Bottom: Genres / Status -->
                        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" VerticalAlignment="Bottom">
                            <!-- Genres -->
                            <TextBlock Grid.Column="0" Text="{Binding Genres, Converter={StaticResource LocConverter}}" FontSize="11" Opacity="0.4" 
                                       MaxLines="1" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            
                            <!-- Status -->
                            <Border Grid.Column="1" 
                                    IsVisible="{Binding Status, Converter={StaticResource StatusNotNoneConverter}}"
                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                                    CornerRadius="3" Padding="7,3">
                                <TextBlock Text="{Binding Status, Converter={StaticResource LocConverter}}" 
                                           FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Margin="20,4,20,16">

        <!-- ═══ Search Bar + Filters (1:1 with My List style) ═══ -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="8,6" Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="10"
                BorderBrush="{DynamicResource CardStrokeColorDefault}" BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto">
                <!-- Search -->
                <TextBox Grid.Column="0" PlaceholderText="{DynamicResource l.search.placeholder}"
                         Text="{Binding SearchQuery}"
                         VerticalAlignment="Center" Height="34"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center"
                         FontSize="13" Padding="8,0">
                    <TextBox.InnerRightContent>
                        <material:MaterialIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Opacity="0.3"/>
                    </TextBox.InnerRightContent>
                </TextBox>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0">
                    <Border Width="1" Height="20" Background="{DynamicResource DividerStrokeColorDefault}" Margin="4,0" VerticalAlignment="Center"/>

                    <!-- Hide in lists toggle -->
                    <ToggleButton IsChecked="{Binding HideInLists}" 
                                  Background="Transparent" BorderThickness="0" Padding="8,6" CornerRadius="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="{Binding HideInLists, Converter={StaticResource LocConverter}, ConverterParameter='eye_logic'}" 
                                                   Width="16" Height="16" Opacity="0.6"/>
                            <TextBlock Text="{DynamicResource l.filters.options.hide_in_lists}" FontSize="12" VerticalAlignment="Center" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleButton.Styles>
                            <Style Selector="ToggleButton:checked">
                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
                            </Style>
                            <Style Selector="ToggleButton:checked material|MaterialIcon">
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                            <Style Selector="ToggleButton:checked TextBlock">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ToggleButton.Styles>
                    </ToggleButton>

                    <Border Width="1" Height="20" Background="{DynamicResource DividerStrokeColorDefault}" Margin="4,0" VerticalAlignment="Center"/>

                    <!-- Adult Filter cycle button -->
                    <Button Command="{Binding CycleAdultFilterCommand}"
                            Background="Transparent" BorderThickness="0" Padding="8,6" CornerRadius="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="{Binding AdultFilter, Converter={StaticResource AdultIconConverter}}" 
                                                   Width="16" Height="16" 
                                                   Foreground="{Binding AdultFilter, Converter={StaticResource AdultColorConverter}}"/>
                            <TextBlock Text="{Binding DisplayAdultFilter}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{Binding AdultFilter, Converter={StaticResource AdultColorConverter}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status & Results -->
        <Panel Grid.Row="1">
            <!-- Loading / Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        IsVisible="{Binding !SearchResults.Count}">
                <material:MaterialIcon Kind="TextBoxSearchOutline" Width="64" Height="64" Opacity="0.1"/>
            </StackPanel>

            <!-- List of Results -->
            <ListBox IsVisible="{Binding SearchResults.Count}"
                     ItemsSource="{Binding SearchResults}"
                     ContainerPrepared="ListBox_ContainerPrepared"
                     Background="Transparent" BorderThickness="0"
                     HorizontalAlignment="Stretch">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="20,0,20,12"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="CornerRadius" Value="12"/>
                        <Setter Property="ClipToBounds" Value="True"/>
                        <Setter Property="Transitions">
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                            </Transitions>
                        </Setter>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <StaticResource ResourceKey="SearchResultTemplate"/>
                </ListBox.ItemTemplate>
            </ListBox>
        </Panel>
    </Grid>
</UserControl>
