<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiriha.ViewModels"
             xmlns:vmAnalytics="using:Kiriha.ViewModels.Analytics"
             xmlns:vmAnimeDetails="using:Kiriha.ViewModels.AnimeDetails"
             xmlns:vmAnimeList="using:Kiriha.ViewModels.AnimeList"
             xmlns:vmHistory="using:Kiriha.ViewModels.History"
             xmlns:vmPlayer="using:Kiriha.ViewModels.Player"
             xmlns:vmSeasonal="using:Kiriha.ViewModels.Seasonal"
             xmlns:vmSettings="using:Kiriha.ViewModels.Settings"
             xmlns:vmTorrents="using:Kiriha.ViewModels.Torrents"
             xmlns:vmSearch="using:Kiriha.ViewModels.Search"
             xmlns:models="using:Kiriha.Models"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:conv="using:Kiriha.Views.Converters"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:u="using:Kiriha.Utils.UI"
             x:Class="Kiriha.Views.HistoryView"
             x:DataType="vmHistory:HistoryViewModel">

    <UserControl.Resources>
        <conv:LocConverter x:Key="LocConverter"/>
        <conv:HistoryActionConverter x:Key="HistoryActionConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- History row hover feedback -->
        <Style Selector="Border.HistoryRow">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.HistoryRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardHoverFillColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ═══ Reveal-on-load: каскад при появлении строк ═══ -->
        <Style Selector="Border.revealItem">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translate(0,16px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.42" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.42" Easing="CubicEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.revealItem.shown">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translate(0,0)"/>
        </Style>

        <!-- ═══ Torrents-style Filter Toggle (period) ═══ -->
        <Style Selector="ToggleButton.FilterToggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ToggleButton.FilterToggle:checked">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="ToggleButton.FilterToggle:checked TextBlock">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *" Margin="0">

        <!-- ═══ Search + Period bar (Torrents-style) ═══ -->
        <Border Grid.Row="0" Margin="20,4,20,12" Padding="8,6"
                Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="10"
                BorderBrush="{DynamicResource CardStrokeColorDefault}" BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchQuery, Mode=TwoWay}"
                         PlaceholderText="{DynamicResource l.history.search_placeholder}"
                         VerticalAlignment="Center" Height="34"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center"
                         FontSize="13" Padding="8,0">
                    <TextBox.InnerRightContent>
                        <material:MaterialIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Opacity="0.3"/>
                    </TextBox.InnerRightContent>
                </TextBox>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" Margin="12,0,4,0">
                    <Border Width="1" Height="20" Background="{DynamicResource DividerStrokeColorDefault}" Margin="4,0" VerticalAlignment="Center"/>

                    <ToggleButton Classes="FilterToggle" IsChecked="{Binding IsPeriodAll, Mode=TwoWay}">
                        <TextBlock Text="{DynamicResource l.history.period.all}" FontSize="12" Opacity="0.6"/>
                    </ToggleButton>
                    <ToggleButton Classes="FilterToggle" IsChecked="{Binding IsPeriodToday, Mode=TwoWay}">
                        <TextBlock Text="{DynamicResource l.history.period.today}" FontSize="12" Opacity="0.6"/>
                    </ToggleButton>
                    <ToggleButton Classes="FilterToggle" IsChecked="{Binding IsPeriodWeek, Mode=TwoWay}">
                        <TextBlock Text="{DynamicResource l.history.period.week}" FontSize="12" Opacity="0.6"/>
                    </ToggleButton>
                    <ToggleButton Classes="FilterToggle" IsChecked="{Binding IsPeriodMonth, Mode=TwoWay}">
                        <TextBlock Text="{DynamicResource l.history.period.month}" FontSize="12" Opacity="0.6"/>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Action-type tabs (AnimeList-style) ═══ -->
        <Border Grid.Row="1" Margin="20,0,20,12" Padding="4"
                Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="8"
                HorizontalAlignment="Center"
                IsVisible="{Binding HasHistory}">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <RadioButton Classes="Pill" GroupName="HistAction"
                             Content="{DynamicResource l.history.actions.all}"
                             IsChecked="{Binding IsActionAll, Mode=TwoWay}"/>
                <RadioButton Classes="Pill" GroupName="HistAction"
                             Content="{DynamicResource l.history.actions.watched}"
                             IsChecked="{Binding IsActionWatched, Mode=TwoWay}"/>
                <RadioButton Classes="Pill" GroupName="HistAction"
                             Content="{DynamicResource l.history.actions.completed}"
                             IsChecked="{Binding IsActionCompleted, Mode=TwoWay}"/>
                <RadioButton Classes="Pill" GroupName="HistAction"
                             Content="{DynamicResource l.history.actions.dropped}"
                             IsChecked="{Binding IsActionDropped, Mode=TwoWay}"/>
                <RadioButton Classes="Pill" GroupName="HistAction"
                             Content="{DynamicResource l.history.actions.score_set_filter}"
                             IsChecked="{Binding IsActionScoreSet, Mode=TwoWay}"/>
            </StackPanel>
        </Border>

        <!-- ═══ Content Area ═══ -->
        <Panel Grid.Row="2">
            <!-- Empty DB -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        IsVisible="{Binding !HasHistory}">
                <material:MaterialIcon Kind="History" Width="64" Height="64" Opacity="0.1"/>
                <TextBlock Text="{DynamicResource l.history.no_history}" FontSize="15" Opacity="0.4" FontWeight="Medium"/>
            </StackPanel>

            <!-- No filter matches -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="HasHistory"/>
                        <Binding Path="!HasResults"/>
                    </MultiBinding>
                </StackPanel.IsVisible>
                <material:MaterialIcon Kind="MagnifyRemoveOutline" Width="56" Height="56" Opacity="0.12"/>
                <TextBlock Text="{DynamicResource l.history.no_results}" FontSize="14" Opacity="0.5" FontWeight="Medium"/>
            </StackPanel>

            <!-- Grouped Timeline -->
            <ScrollViewer IsVisible="{Binding HasResults}" Padding="0,0,0,0" u:SmoothScroll.IsEnabled="True">
                <ItemsControl ItemsSource="{Binding GroupedHistory}" Margin="20,4,20,24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vmHistory:HistoryGroup">
                            <StackPanel Margin="0,0,0,22">
                                <!-- Date Header -->
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                                    <Border Width="8" Height="8" CornerRadius="4"
                                            Background="{DynamicResource SystemAccentColor}"
                                            Margin="6,0,0,0"/>
                                    <TextBlock Text="{Binding Header}" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource SystemAccentColor}"
                                               VerticalAlignment="Center"
                                               LetterSpacing="1.2" Opacity="0.85"/>
                                </StackPanel>

                                <!-- Timeline column with vertical line -->
                                <Grid ColumnDefinitions="Auto, *">
                                    <!-- Vertical line -->
                                    <Border Grid.Column="0" Width="1.5"
                                            Background="{DynamicResource DividerStrokeColorDefault}"
                                            Margin="9,0,0,0"
                                            HorizontalAlignment="Left"/>

                                    <!-- Items -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Items}" Margin="0,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vmHistory:HistoryEntryVm">
                                                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,8">
                                                    <!-- Timeline dot (overlayed on the line) -->
                                                    <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5"
                                                            Background="{DynamicResource SystemAccentColor}"
                                                            VerticalAlignment="Center"
                                                            Margin="5,0,18,0"
                                                            Opacity="0.85"
                                                            BoxShadow="0 0 0 3 #22000000"/>

                                                    <!-- Card -->
                                                    <Border Grid.Column="1" Classes="HistoryRow revealItem"
                                                            Background="{DynamicResource CardBackgroundFillDefault}"
                                                            CornerRadius="12" Padding="12,10"
                                                            BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                                            BorderThickness="1"
                                                            Loaded="OnHistoryRowLoaded"
                                                            DoubleTapped="HistoryItem_DoubleTapped">
                                                        <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                                                            <!-- Poster -->
                                                            <Border Grid.Column="0" Width="42" Height="60"
                                                                    CornerRadius="6" ClipToBounds="True"
                                                                    Background="{DynamicResource SubtleFillColorSecondary}"
                                                                    VerticalAlignment="Center">
                                                                <Panel>
                                                                    <material:MaterialIcon Kind="ImageOutline"
                                                                                           Width="20" Height="20"
                                                                                           Opacity="0.35"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"/>
                                                                    <asyncImageLoader:AdvancedImage
                                                                        Source="{Binding PosterUrl}"
                                                                        Stretch="UniformToFill"/>
                                                                </Panel>
                                                            </Border>

                                                            <!-- Action icon badge -->
                                                            <Border Grid.Column="1" Width="28" Height="28" CornerRadius="14"
                                                                    Background="{DynamicResource SubtleFillColorSecondary}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="12,0,0,0">
                                                                <material:MaterialIcon
                                                                    Kind="{Binding ActionType, Converter={StaticResource HistoryActionConverter}, ConverterParameter='icon'}"
                                                                    Width="14" Height="14"
                                                                    Foreground="{DynamicResource SystemAccentColor}"
                                                                    Opacity="0.85"/>
                                                            </Border>

                                                            <!-- Info -->
                                                            <StackPanel Grid.Column="2" Margin="12,0" VerticalAlignment="Center" Spacing="1">
                                                                <TextBlock Text="{Binding AnimeTitle}"
                                                                           FontSize="13.5" FontWeight="SemiBold"
                                                                           MaxLines="1" TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource SystemBaseHighColor}"/>
                                                                <TextBlock Text="{Binding RussianTitle}"
                                                                           FontSize="11"
                                                                           MaxLines="1" TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource SystemAccentColor}" Opacity="0.85"
                                                                           IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="{Binding ActionType, Converter={StaticResource HistoryActionConverter}}"
                                                                                   FontSize="11" Opacity="0.85"/>
                                                                        <TextBlock Text="{Binding Detail}"
                                                                                   FontSize="11" Opacity="0.85" FontWeight="Medium"
                                                                                   Foreground="{DynamicResource SystemAccentColor}"
                                                                                   IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="·" FontSize="11" Opacity="0.5"
                                                                               IsVisible="{Binding EpisodeLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                    <TextBlock Text="{Binding EpisodeLabel}"
                                                                               FontSize="11" Opacity="0.85" FontWeight="Medium"
                                                                               Foreground="{DynamicResource SystemAccentColor}"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Range count badge -->
                                                            <Border Grid.Column="3" CornerRadius="10"
                                                                    Background="{DynamicResource SystemAccentColor}"
                                                                    Padding="7,2" Margin="0,0,10,0"
                                                                    VerticalAlignment="Center"
                                                                    IsVisible="{Binding IsRange}">
                                                                <TextBlock Text="{Binding Count, StringFormat='×{0}'}"
                                                                           FontSize="10" FontWeight="Bold"
                                                                           Foreground="White"/>
                                                            </Border>

                                                            <!-- Time -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                                       FontSize="11" Opacity="0.4"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </Grid>
</UserControl>
