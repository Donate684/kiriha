<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:controls="using:Kiriha.Views.Controls"
        xmlns:m="using:Kiriha.Models"
        xmlns:views="using:Kiriha.Views"
        x:Class="Kiriha.Views.AboutWindow"
        x:DataType="views:AboutWindow"
        Title=""
        Width="860" Height="530"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/kiriha.ico"
        Background="{x:Null}"
        TransparencyLevelHint="Mica, AcrylicBlur"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="34"
        WindowDecorations="BorderOnly">

    <Window.Styles>

        <!-- ─── Section caption ─── -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2.4"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- ─── Comfortable pill chip ─── -->
        <Style Selector="Button.Chip">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillDefault}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.Chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
        </Style>

        <!-- Tonal version pill -->
        <Style Selector="Border.VersionChip">
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Divider -->
        <Style Selector="Border.Divider">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="Margin" Value="0,14,0,14"/>
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

    </Window.Styles>

    <LayoutTransformControl Name="ScaleRoot">
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </LayoutTransformControl.LayoutTransform>
    <Grid RowDefinitions="34,*" PointerPressed="OnTitleBarPressed">

        <!-- Drag-area -->
        <Border Grid.Row="0" Background="Transparent"/>

        <!-- Custom Caption Buttons -->
        <controls:TitleBarButtons Grid.Row="0" Grid.RowSpan="2"
                                  HorizontalAlignment="Right" VerticalAlignment="Top" ZIndex="999"/>

        <!-- ═══ Body ═══ -->
        <Panel Grid.Row="1" ClipToBounds="True">

            <!-- Background halo (left-tinted) -->
            <Ellipse Width="800" Height="800" Opacity="0.14"
                     HorizontalAlignment="Left" VerticalAlignment="Center"
                     Margin="-300,0,0,0"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="50%,50%" Center="50%,50%" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Offset="0"   Color="{DynamicResource SystemAccentColorLight2}"/>
                        <GradientStop Offset="0.5" Color="{DynamicResource SystemAccentColor}"/>
                        <GradientStop Offset="1"   Color="#00000000"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Two-column layout with broader columns -->
            <Grid ColumnDefinitions="310,1,*" Margin="24,16,20,16">

                <!-- ── Vertical separator ── -->
                <Border Grid.Column="1" Width="1"
                        Background="{DynamicResource CardStrokeColorDefault}"
                        Opacity="0.35" Margin="0,8,0,8"/>

                <!-- ── LEFT: Hero ── -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top"
                            Spacing="0" Margin="0,0,16,0">

                    <controls:LeafLogo Width="128" Height="128" ShowHalo="False"
                                       HorizontalAlignment="Center"/>

                    <TextBlock Text="Kiriha" FontSize="34" FontWeight="Thin"
                               LetterSpacing="6" Opacity="0.95" Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>

                    <Border Classes="VersionChip" Margin="0,6,0,0" HorizontalAlignment="Center">
                        <TextBlock Name="VersionLabel" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="2.2" Opacity="0.85"
                                   Foreground="{DynamicResource SystemAccentColor}"/>
                    </Border>

                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.55"
                               LineHeight="17" Margin="0,14,0,0"
                               TextAlignment="Center"
                               Text="{DynamicResource l.about.description}"/>

                    <Border Classes="Divider"/>

                    <TextBlock FontSize="10" Opacity="0.4" TextWrapping="Wrap"
                               LineHeight="14" TextAlignment="Center"
                               Text="{DynamicResource l.about.license_note}"/>
                </StackPanel>

                <!-- ── RIGHT: Credits ── -->
                <ScrollViewer Grid.Column="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Margin="20,0,0,0">
                    <StackPanel Spacing="0" VerticalAlignment="Center">

                        <!-- Data Sources -->
                        <TextBlock Classes="SectionHeader" Margin="0,6,0,6"
                                   Text="{DynamicResource l.about.data_sources}"/>
                        <ItemsControl ItemsSource="{Binding DataSources}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:CenteredWrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:CreditEntry">
                                    <Button Classes="Chip" Click="OnEntryClick"
                                            Tag="{Binding Url}" ToolTip.Tip="{Binding Note}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon Kind="Database" Width="12" Height="12"
                                                                   VerticalAlignment="Center" Opacity="0.65"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Inspirations -->
                        <TextBlock Classes="SectionHeader" Margin="0,16,0,6"
                                   Text="{DynamicResource l.about.inspirations}"/>
                        <ItemsControl ItemsSource="{Binding Inspirations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:CenteredWrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:CreditEntry">
                                    <Button Classes="Chip" Click="OnEntryClick"
                                            Tag="{Binding Url}" ToolTip.Tip="{Binding Note}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon Kind="LightbulbOutline" Width="12" Height="12"
                                                                   VerticalAlignment="Center" Opacity="0.65"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Libraries -->
                        <TextBlock Classes="SectionHeader" Margin="0,16,0,6"
                                   Text="{DynamicResource l.about.libraries}"/>
                        <ItemsControl ItemsSource="{Binding Libraries}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:CenteredWrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:CreditEntry">
                                    <Button Classes="Chip" Click="OnEntryClick"
                                            Tag="{Binding Url}" ToolTip.Tip="{Binding Note}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon Kind="Package" Width="12" Height="12"
                                                                   VerticalAlignment="Center" Opacity="0.65"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Panel>

    </Grid>
    </LayoutTransformControl>
</Window>
