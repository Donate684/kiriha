<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiriha.ViewModels"
             xmlns:vmAnalytics="using:Kiriha.ViewModels.Analytics"
             xmlns:vmAnimeDetails="using:Kiriha.ViewModels.AnimeDetails"
             xmlns:vmAnimeList="using:Kiriha.ViewModels.AnimeList"
             xmlns:vmHistory="using:Kiriha.ViewModels.History"
             xmlns:vmPlayer="using:Kiriha.ViewModels.Player"
             xmlns:vmSeasonal="using:Kiriha.ViewModels.Seasonal"
             xmlns:vmSettings="using:Kiriha.ViewModels.Settings"
             xmlns:vmTorrents="using:Kiriha.ViewModels.Torrents"
             xmlns:vmSearch="using:Kiriha.ViewModels.Search"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:u="using:Kiriha.Utils.UI"
        x:Class="Kiriha.Views.Player.PlayerSelectionWindow"
        x:DataType="vmPlayer:PlayerSelectionViewModel"
        Title="{DynamicResource l.scrobbler.processes.tracked_apps}"
        Width="650" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True">

    <Panel PointerPressed="OnPointerPressed">
        <!-- Pure background from theme -->
        <Border Background="{DynamicResource SystemAltLowColor}" Opacity="0.5"/>

        <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="0">
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="24,40,24,20">
                <TextBlock Text="{DynamicResource l.scrobbler.processes.tracked_apps}" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource l.scrobbler.processes.tracked_apps_sub}" FontSize="12" Opacity="0.5"/>
            </StackPanel>

            <!-- Search and Multi-select -->
            <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="24,0,24,16">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" PlaceholderText="{DynamicResource l.scrobbler.processes.search_placeholder}" 
                         Classes="revealPasswordButton" CornerRadius="6">
                    <TextBox.InnerLeftContent>
                        <material:MaterialIcon Kind="Magnify" Width="18" Height="18" Margin="10,0,0,0" Opacity="0.5"/>
                    </TextBox.InnerLeftContent>
                </TextBox>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,0,0">
                    <Button Command="{Binding SelectAllCommand}"
                            Background="{DynamicResource SubtleFillColorSecondary}" Padding="12,6" CornerRadius="6">
                        <TextBlock Text="{DynamicResource l.common.actions.select_all}" FontSize="11"/>
                    </Button>
                    <Button Command="{Binding DeselectAllCommand}"
                            Background="{DynamicResource SubtleFillColorSecondary}" Padding="12,6" CornerRadius="6">
                        <TextBlock Text="{DynamicResource l.common.actions.deselect_all}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="2" u:SmoothScroll.IsEnabled="True">
                <StackPanel Spacing="24" Margin="24,0,24,24">
                    
                    <!-- Active/Running Players -->
                    <StackPanel Spacing="12" IsVisible="{Binding ActivePlayers.Count}">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon Kind="LightningBolt" Width="18" Height="18" Foreground="#2ecc71"/>
                                <TextBlock Text="{DynamicResource l.scrobbler.status.detected}" FontWeight="SemiBold" FontSize="15" Foreground="#2ecc71"/>
                                <TextBlock Text="{Binding ActivePlayers.Count, StringFormat='({0})'}" Opacity="0.3" VerticalAlignment="Bottom" FontSize="12" Margin="4,0,0,2"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource l.scrobbler.matching.sources_tip}" FontSize="11" Opacity="0.4" Margin="26,0,0,0"/>
                        </StackPanel>
                        
                        <ItemsControl ItemsSource="{Binding ActivePlayers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#152ecc71" BorderBrush="#302ecc71" BorderThickness="1" CornerRadius="8" Margin="0,0,8,8" Padding="12,8" Width="190">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" FontWeight="Medium" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" OnContent="" OffContent="" MinWidth="0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Video Players -->
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="PlayCircleOutline" Width="18" Height="18" Foreground="{DynamicResource SystemAccentColor}"/>
                            <TextBlock Text="{DynamicResource l.scrobbler.processes.video_players}" FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock Text="{Binding VideoPlayers.Count, StringFormat='({0})'}" Opacity="0.3" VerticalAlignment="Bottom" FontSize="12" Margin="4,0,0,2"/>
                        </StackPanel>
                        
                        <ItemsControl ItemsSource="{Binding VideoPlayers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="8" Margin="0,0,8,8" Padding="12,8" Width="190">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" OnContent="" OffContent="" MinWidth="0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Web Browsers -->
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="Web" Width="18" Height="18" Foreground="{DynamicResource SystemAccentColor}"/>
                            <TextBlock Text="{DynamicResource l.scrobbler.processes.web_browsers}" FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock Text="{Binding WebBrowsers.Count, StringFormat='({0})'}" Opacity="0.3" VerticalAlignment="Bottom" FontSize="12" Margin="4,0,0,2"/>
                        </StackPanel>
                        
                        <ItemsControl ItemsSource="{Binding WebBrowsers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="8" Margin="0,0,8,8" Padding="12,8" Width="190">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" OnContent="" OffContent="" MinWidth="0" Margin="4,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" Margin="0,20,0,0" Padding="0,16,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefault}" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0" Text="{DynamicResource l.scrobbler.rules.applied_prompt}" Opacity="0.4" FontSize="11" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="{DynamicResource l.common.actions.save_and_close}" 
                            Command="{Binding SaveAndCloseCommand}" 
                            CommandParameter="{Binding $parent[Window]}"
                            Background="{DynamicResource SystemAccentColor}" Foreground="White"
                            Padding="24,10" CornerRadius="6" FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
