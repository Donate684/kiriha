<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiriha.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:core="using:Kiriha.Core"
             xmlns:u="using:Kiriha.Utils"
             x:Class="Kiriha.Views.AnalyticsView"
             x:DataType="vm:AnalyticsViewModel"
             x:Name="analyticsRoot">

    <UserControl.Resources>

        <!-- ═══ MetricTemplate — крупная карточка с иконкой и большой цифрой ═══ -->
        <DataTemplate x:Key="MetricTemplate" x:DataType="vm:AnalyticsMetric">
            <Border Classes="AnalyticsPanel MetricPanel" Margin="0,0,10,0">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                    <TextBlock Text="{Binding Label}"
                               FontSize="11"
                               FontWeight="Medium"
                               Opacity="0.55"
                               LetterSpacing="0.5"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding Value}"
                               FontSize="32"
                               FontWeight="Light"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2"
                               Text="{Binding Hint}"
                               FontSize="10.5"
                               Opacity="0.42"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ BarTemplate — строка прогресса ═══ -->
        <DataTemplate x:Key="BarTemplate" x:DataType="vm:AnalyticsBar">
            <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,11">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Label}" FontSize="12" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" Opacity="0.65"/>
                </Grid>
                <ProgressBar Grid.Row="1" Classes="AnalyticsBar" Value="{Binding Percent}" Margin="0,5,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- ═══ StatusTileTemplate — плитка статуса с акцент-полосой ═══ -->
        <DataTemplate x:Key="StatusTileTemplate" x:DataType="vm:AnalyticsBar">
            <Border Background="{DynamicResource SubtleFillColorTertiary}"
                    CornerRadius="10"
                    Padding="0"
                    Margin="0,0,8,8"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <!-- Цветная полоса акцента слева -->
                    <Border Grid.Column="0"
                            Background="{Binding Accent}"
                            CornerRadius="10,0,0,10"/>

                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="5" Margin="10,10,10,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="1"
                                    Background="{Binding Accent}"
                                    CornerRadius="8"
                                    Padding="8,2">
                                <TextBlock Text="{Binding Value}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding ShareText}"
                                   FontSize="10.5"
                                   Opacity="0.52"/>
                        <ProgressBar Grid.Row="2"
                                     Classes="AnalyticsBar"
                                     Value="{Binding Percent}"
                                     Foreground="{Binding Accent}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ TasteHighlightTemplate ═══ -->
        <DataTemplate x:Key="TasteHighlightTemplate" x:DataType="vm:AnalyticsBar">
            <Border Classes="AnalyticsPanel" Margin="0,0,10,0" MinHeight="112">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Width="30" Height="4" CornerRadius="2"
                            Background="{Binding Accent}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding Label}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               MaxLines="2"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Value, StringFormat='{}{0} тайтл.'}"
                                   FontSize="11"
                                   Opacity="0.62"/>
                        <TextBlock Text="{Binding ShareText, StringFormat='лидер {0}'}"
                                   FontSize="11"
                                   Opacity="0.42"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ TasteRowTemplate — ranked-строка жанра/студии ═══ -->
        <DataTemplate x:Key="TasteRowTemplate" x:DataType="vm:AnalyticsBar">
            <Border Background="{DynamicResource SubtleFillColorTertiary}"
                    CornerRadius="10"
                    Padding="10,9"
                    Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Border Width="8"
                            Height="34"
                            CornerRadius="4"
                            Background="{Binding Accent}"
                            VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Opacity="0.65"/>
                        </Grid>
                        <ProgressBar Classes="AnalyticsBar"
                                     Value="{Binding Percent}"
                                     Foreground="{Binding Accent}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding ShareText}"
                               FontSize="11"
                               Opacity="0.45"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ ReleaseYearTemplate ═══ -->
        <DataTemplate x:Key="ReleaseYearTemplate" x:DataType="vm:AnalyticsBar">
            <Border Background="{DynamicResource SubtleFillColorTertiary}"
                    CornerRadius="8"
                    Margin="2"
                    Height="62"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="{Binding Accent}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="8,6,8,4">
                        <TextBlock Text="{Binding Label}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Opacity="0.55"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding Value}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ FavoriteRowTemplate — кликабельная ranked-строка ═══ -->
        <DataTemplate x:Key="FavoriteRowTemplate" x:DataType="vm:AnalyticsFavoriteRow">
            <Button Classes="FavoriteRowButton"
                    Command="{Binding #analyticsRoot.((vm:AnalyticsViewModel)DataContext).OpenFavoriteCommand}"
                    CommandParameter="{Binding}"
                    ToolTip.Tip="Показать тайтлы">
                <Border Background="{DynamicResource SubtleFillColorTertiary}"
                        CornerRadius="10"
                        Padding="0"
                        Margin="0,0,0,8"
                        ClipToBounds="True">
                    <Grid ColumnDefinitions="4,*">
                        <!-- Цветная полоса акцента слева -->
                        <Border Grid.Column="0"
                                Background="{Binding Accent}"
                                CornerRadius="10,0,0,10"/>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="5" Margin="10,10,10,10">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding Rank, StringFormat='{}#{0}'}"
                                           FontSize="12.5"
                                           FontWeight="Bold"
                                           Foreground="{Binding Accent}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Background="{Binding Accent}"
                                        CornerRadius="8"
                                        Padding="8,2">
                                    <TextBlock Text="{Binding WeightedScore}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Summary}"
                                       FontSize="10.5"
                                       Opacity="0.52"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Grid.Row="2"
                                         Classes="AnalyticsBar"
                                         Value="{Binding Percent}"
                                         Foreground="{Binding Accent}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <!-- ═══ ProfileTodoTemplate — карточка «что посмотреть» ═══ -->
        <DataTemplate x:Key="ProfileTodoTemplate" x:DataType="vm:ProfileTodoItem">
            <Border Background="{DynamicResource SubtleFillColorTertiary}"
                    CornerRadius="10"
                    Padding="0"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <!-- Цветная полоса акцента слева -->
                    <Border Grid.Column="0"
                            Background="{Binding Accent}"
                            CornerRadius="10,0,0,10"/>

                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="10" MinWidth="0">
                        <!-- Постер с закруглёнными краями -->
                        <Border Width="44"
                                Height="62"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Background="{DynamicResource SubtleFillColorSecondary}">
                            <Panel>
                                <material:MaterialIcon Kind="ImageOutline"
                                                       Width="18"
                                                       Height="18"
                                                       Opacity="0.22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                <Image core:CachedImage.Source="{Binding PosterUrl}"
                                       Stretch="UniformToFill"/>
                            </Panel>
                        </Border>

                        <!-- Информация -->
                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" VerticalAlignment="Center" MinWidth="0">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,3"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Subtitle}"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource SystemAccentColor}"
                                       Opacity="0.75"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Margin="0,0,0,3"/>
                            <TextBlock Grid.Row="2"
                                       Text="{Binding Detail}"
                                       FontSize="11"
                                       Opacity="0.52"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- Бейдж -->
                        <Border Grid.Column="2"
                                Background="{Binding Accent}"
                                CornerRadius="8"
                                Padding="9,4"
                                VerticalAlignment="Center"
                                Margin="6,0,0,0">
                            <TextBlock Text="{Binding Badge}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <UserControl.Styles>
        <StyleInclude Source="avares://Kiriha/Views/Styles/AnalyticsViewStyles.axaml"/>
    </UserControl.Styles>

    <Panel>
        <!-- ═══════════════ Основной контент ═══════════════ -->
        <Grid RowDefinitions="Auto,Auto,*" Margin="0" IsVisible="{Binding HasData}">

            <!-- ═══ HERO-БАННЕР (без дублирующихся метрик) ═══ -->
            <Border Grid.Row="0" Margin="20,8,20,14" CornerRadius="14"
                    BorderBrush="{DynamicResource CardStrokeColorDefault}"
                    BorderThickness="1"
                    Background="{DynamicResource CardBackgroundFillDefault}"
                    ClipToBounds="True">
                <Panel>
                    <!-- Градиентный тинт слева -->
                    <Border CornerRadius="14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="85%,100%">
                                <GradientStop Color="#1A2D7DD2" Offset="0"/>
                                <GradientStop Color="#007B61FF" Offset="0.6"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Акцентная полоса сверху -->
                    <Border Height="3" VerticalAlignment="Top" CornerRadius="14,14,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#FF7B61FF" Offset="0"/>
                                <GradientStop Color="#FF2D7DD2" Offset="0.5"/>
                                <GradientStop Color="#FF2E9D62" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Основной контент -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,18,20,18" ColumnSpacing="18">

                        <!-- Аватар с градиентным кольцом -->
                        <Panel Width="62" Height="62" VerticalAlignment="Center">
                            <!-- Кольцо (градиентный фон) -->
                            <Border CornerRadius="31">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#FF7B61FF" Offset="0"/>
                                        <GradientStop Color="#FF2D7DD2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Внутренний круг -->
                            <Border Width="54" Height="54" CornerRadius="27"
                                    Background="{DynamicResource CardBackgroundFillDefault}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <material:MaterialIcon Kind="AccountCircle"
                                                       Width="30" Height="30"
                                                       Foreground="{DynamicResource SystemAccentColor}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                            </Border>
                        </Panel>

                        <!-- Заголовок -->
                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="Мой профиль"
                                       FontSize="21"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Статистика аниме-библиотеки"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>

                        <!-- Декоративные стат-пузыри (2 ключевых показателя) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                            <!-- Всего тайтлов -->
                            <Border CornerRadius="12" Padding="14,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#1A7B61FF" Offset="0"/>
                                        <GradientStop Color="#0D2D7DD2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Metrics[0].Value}"
                                               FontSize="22" FontWeight="Light"
                                               HorizontalAlignment="Center"
                                               Foreground="#FF7B61FF"/>
                                    <TextBlock Text="{Binding Metrics[0].Label}"
                                               FontSize="10" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Завершено -->
                            <Border CornerRadius="12" Padding="14,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#162E9D62" Offset="0"/>
                                        <GradientStop Color="#0D2D7DD2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Metrics[1].Value}"
                                               FontSize="22" FontWeight="Light"
                                               HorizontalAlignment="Center"
                                               Foreground="#FF2E9D62"/>
                                    <TextBlock Text="{Binding Metrics[1].Label}"
                                               FontSize="10" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Средняя оценка -->
                            <Border CornerRadius="12" Padding="14,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#1AD17A22" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Metrics[2].Value}"
                                               FontSize="22" FontWeight="Light"
                                               HorizontalAlignment="Center"
                                               Foreground="#FFD17A22"/>
                                    <TextBlock Text="{Binding Metrics[2].Label}"
                                               FontSize="10" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Panel>
            </Border>

            <!-- ═══ TAB-НАВИГАЦИЯ ═══ -->
            <Border Grid.Row="1" Padding="4"
                    Background="{DynamicResource SubtleFillColorSecondary}"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    Margin="20,0,20,14">
                <StackPanel Orientation="Horizontal" Spacing="2">

                    <RadioButton Classes="SectionTab" GroupName="AnalyticsSections"
                                 IsChecked="{Binding IsOverviewSelected, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="ChartBoxOutline" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Профиль" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Classes="SectionTab" GroupName="AnalyticsSections"
                                 IsChecked="{Binding IsTasteSelected, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="HeartOutline" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Вкусы" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Classes="SectionTab" GroupName="AnalyticsSections"
                                 IsChecked="{Binding IsWatchNextSelected, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="PlaylistPlay" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Что посмотреть" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Classes="SectionTab" GroupName="AnalyticsSections"
                                 IsChecked="{Binding IsHistorySelected, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="History" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="История" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </Border>

            <!-- ═══ КОНТЕНТ СЕКЦИЙ ═══ -->
            <ScrollViewer Grid.Row="2"
                          Padding="0,0,0,42"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          u:SmoothScroll.IsEnabled="True">
                <Grid Margin="20,0,20,0">

                    <!-- ══════════ СЕКЦИЯ: ПРОФИЛЬ (Overview) ══════════ -->
                    <StackPanel Spacing="16"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsOverviewSelected}">

                        <!-- Мой список + Распределение оценок -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

                            <!-- Мой список -->
                            <Border Classes="AnalyticsPanel" VerticalAlignment="Top">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="{DynamicResource SystemAccentColor}"
                                                VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="PlaylistCheck"
                                                                   Width="16" Height="16"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Мой список" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="По статусам просмотра" FontSize="10.5" Opacity="0.45"/>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding StatusDistribution}" ItemTemplate="{StaticResource StatusTileTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Распределение оценок — вертикальный гистограмм -->
                            <Border Grid.Column="1" Classes="AnalyticsPanel" VerticalAlignment="Top">
                                <StackPanel Spacing="16">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="#FF2E9D62"
                                                VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="StarOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Оценки" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Распределение по баллам" FontSize="10.5" Opacity="0.45"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Вертикальный chart —  10 → 1 слева направо -->
                                    <ItemsControl ItemsSource="{Binding ScoreDistribution}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AnalyticsBar">
                                                <Grid RowDefinitions="Auto,72,Auto" Margin="2,0">

                                                    <!-- Кол-во сверху -->
                                                    <TextBlock Text="{Binding Value}"
                                                               FontSize="9"
                                                               HorizontalAlignment="Center"
                                                               Opacity="0.6"
                                                               Margin="0,0,0,3"/>

                                                    <!-- Область бара фиксированной высоты -->
                                                    <Grid Grid.Row="1">
                                                        <!-- Фоновый трек -->
                                                        <Border Background="{DynamicResource SubtleFillColorSecondary}"
                                                                CornerRadius="4"
                                                                VerticalAlignment="Stretch"/>
                                                        <!-- Цветной бар от низа -->
                                                        <Border Background="{Binding Accent}"
                                                                Height="{Binding BarHeight}"
                                                                VerticalAlignment="Bottom"
                                                                CornerRadius="4,4,0,0"/>
                                                    </Grid>

                                                    <!-- Оценка снизу -->
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Label}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,5,0,0"
                                                               Opacity="0.7"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>


                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Height="110" IsHitTestVisible="False"/>
                    </StackPanel>

                    <!-- ══════════ СЕКЦИЯ: ВКУСЫ ══════════ -->
                    <StackPanel Spacing="16"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsTasteSelected}">

                        <ItemsControl ItemsSource="{Binding TasteHighlights}" ItemTemplate="{StaticResource TasteHighlightTemplate}" IsVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">

                            <!-- Любимые жанры -->
                            <Border Classes="AnalyticsPanel">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="#FFE53935"
                                                VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="ShapeOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Любимые жанры" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="По взвешенной оценке" FontSize="10.5" Opacity="0.45"/>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FavoriteGenres}" ItemTemplate="{StaticResource FavoriteRowTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Любимые студии -->
                            <Border Grid.Column="1" Classes="AnalyticsPanel">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="#FF2D7DD2"
                                                VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="MovieOpenOutline"
                                                                   Width="16" Height="16"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Любимые студии" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="По взвешенной оценке" FontSize="10.5" Opacity="0.45"/>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FavoriteStudios}" ItemTemplate="{StaticResource FavoriteRowTemplate}"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                        <Border Height="150" IsHitTestVisible="False"/>
                    </StackPanel>

                    <!-- ══════════ СЕКЦИЯ: ЧТО ПОСМОТРЕТЬ ══════════ -->
                    <StackPanel Spacing="16"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsWatchNextSelected}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левый столбец -->
                            <StackPanel Grid.Column="0" Spacing="16" MinWidth="0">

                                <!-- Догнать онгоинги -->
                                <Border Classes="AnalyticsPanel" MinHeight="0" MinWidth="0">
                                    <StackPanel Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border Width="30" Height="30" CornerRadius="8"
                                                    Background="#FFE53935"
                                                    VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="PlaylistPlay"
                                                                       Width="16" Height="16"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="Догнать онгоинги" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Текущие аниме с пропущенными сериями" FontSize="10.5" Opacity="0.45" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding WatchTodo}"
                                                      ItemTemplate="{StaticResource ProfileTodoTemplate}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Скоро выйдет -->
                                <Border Classes="AnalyticsPanel" MinHeight="0" MinWidth="0">
                                    <StackPanel Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border Width="30" Height="30" CornerRadius="8"
                                                    Background="#FF2D7DD2"
                                                    VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="CalendarClock"
                                                                       Width="16" Height="16"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="Скоро выйдет" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Следующие эпизоды из списка" FontSize="10.5" Opacity="0.45" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding UpcomingTodo}"
                                                      ItemTemplate="{StaticResource ProfileTodoTemplate}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- Правый столбец -->
                            <StackPanel Grid.Column="1" Spacing="16" MinWidth="0">

                                <!-- Догнать вышедшее -->
                                <Border Classes="AnalyticsPanel" MinHeight="0" MinWidth="0">
                                    <StackPanel Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border Width="30" Height="30" CornerRadius="8"
                                                    Background="#FF7B61FF"
                                                    VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="PlaylistCheck"
                                                                       Width="16" Height="16"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="Догнать вышедшее" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Завершённые аниме с пропущенным" FontSize="10.5" Opacity="0.45" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding FinishedWatchTodo}"
                                                      ItemTemplate="{StaticResource ProfileTodoTemplate}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Планы -->
                                <Border Classes="AnalyticsPanel" MinHeight="0" MinWidth="0">
                                    <StackPanel Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border Width="30" Height="30" CornerRadius="8"
                                                    Background="#FF2E9D62"
                                                    VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="BookmarkPlusOutline"
                                                                       Width="16" Height="16"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="Планы" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Лучшее из запланированного" FontSize="10.5" Opacity="0.45" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding PlanTodo}"
                                                      ItemTemplate="{StaticResource ProfileTodoTemplate}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>
                        <Border Height="110" IsHitTestVisible="False"/>
                    </StackPanel>

                    <!-- ══════════ СЕКЦИЯ: ИСТОРИЯ ══════════ -->
                    <StackPanel Spacing="16"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsHistorySelected}">

                        <!-- График активности + статистика -->
                        <Grid ColumnDefinitions="*,175" ColumnSpacing="16">

                            <!-- График -->
                            <Border Classes="AnalyticsPanel" MinHeight="238">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="#FF7B61FF"
                                                VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="ChartBar"
                                                                   Width="16" Height="16"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Недавняя активность" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Эпизодов за 14 дней" FontSize="10.5" Opacity="0.45"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*" MinHeight="178">
                                        <TextBlock Text="Эпизоды"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.65"
                                                   VerticalAlignment="Center"
                                                   RenderTransform="rotate(-90deg)"/>

                                        <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="0,0,0,0">
                                            <ItemsControl ItemsSource="{Binding RecentHistory}" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:AnalyticsDailyHistoryPoint">
                                                        <Button Classes="ChartPointButton"
                                                                Command="{Binding #analyticsRoot.((vm:AnalyticsViewModel)DataContext).OpenDailyHistoryCommand}"
                                                                CommandParameter="{Binding}"
                                                                HorizontalAlignment="Stretch"
                                                                ToolTip.Tip="{Binding Tooltip}">
                                                            <Grid RowDefinitions="Auto,122,Auto" Margin="2,0" VerticalAlignment="Center">

                                                                <!-- Кол-во сверху (только если > 0) -->
                                                                <TextBlock Text="{Binding Count}"
                                                                           FontSize="9"
                                                                           HorizontalAlignment="Center"
                                                                           Opacity="0.6"
                                                                           Margin="0,0,0,3"
                                                                           MinHeight="13"
                                                                           IsVisible="{Binding HasCount}"/>
                                                                <!-- Распорка для дней где 0 -->
                                                                <Border MinHeight="13" Margin="0,0,0,3" IsVisible="{Binding !HasCount}"/>

                                                                <!-- Область бара фиксированной высоты -->
                                                                <Grid Grid.Row="1">
                                                                    <!-- Фоновый трек -->
                                                                    <Border Background="{DynamicResource SubtleFillColorSecondary}"
                                                                            CornerRadius="4"
                                                                            VerticalAlignment="Stretch"/>
                                                                    <!-- Цветной бар от низа -->
                                                                    <Border Background="{DynamicResource SystemAccentColor}"
                                                                            Height="{Binding BarHeight}"
                                                                            VerticalAlignment="Bottom"
                                                                            Opacity="{Binding Alpha}"
                                                                            CornerRadius="4,4,0,0"/>
                                                                </Grid>

                                                                <!-- Метка дня снизу -->
                                                                <TextBlock Grid.Row="2"
                                                                           Text="{Binding Label}"
                                                                           FontSize="9"
                                                                           HorizontalAlignment="Center"
                                                                           Margin="0,5,0,0"
                                                                           Opacity="0.65"/>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Grid.Row="1"
                                                       Text="Дней назад"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Opacity="0.65"
                                                       Margin="0,8,0,0"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Статистика 14 дней -->
                            <Border Grid.Column="1" Classes="AnalyticsPanel" Padding="0" ClipToBounds="True">
                                <Grid ColumnDefinitions="4,*">
                                    <Border Grid.Column="0" Background="#FF7B61FF" CornerRadius="10,0,0,10"/>
                                    <Border Grid.Column="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#1A7B61FF" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel VerticalAlignment="Center" Spacing="24" Margin="16">
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <TextBlock Text="За 14 дней" FontSize="11" FontWeight="Medium" Opacity="0.5" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding RecentHistoryEpisodes}" FontSize="36" FontWeight="Light" HorizontalAlignment="Center" Foreground="#FF7B61FF"/>
                                                <TextBlock Text="эпизодов" FontSize="11" HorizontalAlignment="Center" Opacity="0.65"/>
                                            </StackPanel>
                                            <Border Height="1" Background="{DynamicResource DividerStrokeColorDefault}" Margin="10,0"/>
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <TextBlock Text="Разных тайтлов" FontSize="11" FontWeight="Medium" Opacity="0.5" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding RecentHistoryTitles}" FontSize="36" FontWeight="Light" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Просмотрено по году выхода -->
                        <Border Classes="AnalyticsPanel">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border Width="30" Height="30" CornerRadius="8"
                                            Background="#FF7B61FF"
                                            VerticalAlignment="Center">
                                        <material:MaterialIcon Kind="CalendarRange"
                                                               Width="16" Height="16"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="По году выхода" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Завершённые тайтлы по году премьеры" FontSize="10.5" Opacity="0.45"/>
                                    </StackPanel>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding ReleaseYearCompletions}"
                                              ItemTemplate="{StaticResource ReleaseYearTemplate}"
                                              ToolTip.Tip="Насыщенность показывает, сколько завершённых тайтлов вышло в этом году">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="12"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Завершения по месяцам (heatmap) -->
                        <Border Classes="AnalyticsPanel" IsVisible="{Binding HasMonthlyHistory}">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border Width="30" Height="30" CornerRadius="8"
                                            Background="#FF0F7B83"
                                            VerticalAlignment="Center">
                                        <material:MaterialIcon Kind="CalendarMonthOutline"
                                                               Width="16" Height="16"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Завершения по месяцам" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Тепловая карта завершённых тайтлов" FontSize="10.5" Opacity="0.45"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="52,*">
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding MonthHeaders}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="12"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,6" Opacity="0.6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding MonthlyHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AnalyticsMonthlyHistoryRow">
                                            <Grid ColumnDefinitions="52,*" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Year}" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Months}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="12"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:AnalyticsMonthlyHistoryCell">
                                                            <Button Classes="ChartPointButton"
                                                                    Command="{Binding #analyticsRoot.((vm:AnalyticsViewModel)DataContext).OpenMonthlyHistoryCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    HorizontalAlignment="Stretch"
                                                                    ToolTip.Tip="{Binding Tooltip}">
                                                                <Border Classes="MonthCell"
                                                                        Classes.current="{Binding IsCurrentMonth}"
                                                                        Background="{Binding Fill}"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="1">
                                                                    <TextBlock Text="{Binding Count}"
                                                                               FontSize="10"
                                                                               Foreground="{Binding TextColor}"
                                                                               FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               IsVisible="{Binding HasCount}"/>
                                                                </Border>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Заглушка если нет дат -->
                        <Border Classes="AnalyticsPanel" IsVisible="{Binding !HasMonthlyHistory}">
                            <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                <material:MaterialIcon Kind="CalendarBlankOutline" Width="32" Height="32" Opacity="0.25" HorizontalAlignment="Center"/>
                                <TextBlock Text="У завершённых тайтлов пока нет дат завершения, поэтому месячная карта пустая."
                                           FontSize="13"
                                           Opacity="0.55"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Height="110" IsHitTestVisible="False"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ═══ ЗАГЛУШКА при отсутствии данных ═══ -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                    IsVisible="{Binding !HasData}">
            <Border Width="80" Height="80" CornerRadius="40"
                    Background="{DynamicResource SubtleFillColorSecondary}"
                    HorizontalAlignment="Center">
                <material:MaterialIcon Kind="ChartTimelineVariant" Width="40" Height="40" Opacity="0.25"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Аналитика появится после синхронизации списка"
                       FontSize="15"
                       Opacity="0.55"
                       HorizontalAlignment="Center"/>
            <Button Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Center"
                    Padding="20,10"
                    CornerRadius="10"/>
        </StackPanel>

        <!-- ═══ ИСТОРИЯ POPUP ═══ -->
        <Border IsVisible="{Binding IsHistoryPopupOpen}"
                Background="#80000000"
                ZIndex="50">
            <Grid>
                <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Command="{Binding CloseHistoryPopupCommand}"/>

                <Border Width="560"
                        MaxHeight="640"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ModalBackgroundFill}"
                        BorderBrush="{DynamicResource CardStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="0"
                        ClipToBounds="True"
                        BoxShadow="0 20 60 0 #70000000">
                    <Grid RowDefinitions="Auto,*">

                        <!-- Шапка попапа -->
                        <Border Grid.Row="0"
                                Padding="20,16"
                                Background="{DynamicResource SubtleFillColorSecondary}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding HistoryPopupTitle}"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HistoryPopupSubtitle}"
                                               FontSize="12"
                                               Opacity="0.52"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Width="32" Height="32"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="16"
                                        Command="{Binding CloseHistoryPopupCommand}">
                                    <material:MaterialIcon Kind="Close" Width="18" Height="18" Opacity="0.65"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Список записей -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto"
                                      u:SmoothScroll.IsEnabled="True">
                            <ItemsControl ItemsSource="{Binding HistoryPopupEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AnalyticsHistoryEntry">
                                        <Border Background="{DynamicResource CardBackgroundFillDefault}"
                                                BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border Width="44"
                                                        Height="60"
                                                        CornerRadius="7"
                                                        ClipToBounds="True"
                                                        Background="{DynamicResource SubtleFillColorSecondary}">
                                                    <Panel>
                                                        <material:MaterialIcon Kind="ImageOutline"
                                                                               Width="18" Height="18"
                                                                               Opacity="0.22"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                        <Image core:CachedImage.Source="{Binding PosterUrl}"
                                                               Stretch="UniformToFill"/>
                                                    </Panel>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Spacing="3"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SystemAccentColor}"
                                                               Opacity="0.75"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis"
                                                               IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Detail}"
                                                           FontSize="12"
                                                           Opacity="0.58"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</UserControl>
