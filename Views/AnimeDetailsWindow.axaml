<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiriha.ViewModels"
        xmlns:models="using:Kiriha.Models"
        xmlns:entities="using:Kiriha.Models.Entities"
        xmlns:controls="using:Kiriha.Views.Controls"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:conv="using:Kiriha.Converters"
        xmlns:u="using:Kiriha.Utils"
        x:Class="Kiriha.Views.AnimeDetailsWindow"
        x:DataType="vm:AnimeDetailsViewModel"
        x:Name="Root"
        Title=""
        Width="880" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{x:Null}"
        TransparencyLevelHint="Mica, AcrylicBlur"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="34"
        WindowDecorations="BorderOnly">

    <Window.Resources>
        <conv:LocConverter x:Key="LocConverter"/>
        <conv:RatingConverter x:Key="RatingConverter"/>
        <conv:FilePathToBitmapConverter x:Key="FilePathToBitmapConverter"/>
        <conv:IntToBooleanConverter x:Key="IntToBoolConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.ContentCard">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillDefault}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #08000000"/>
        </Style>
        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > Control">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > TextBlock">
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > TextBlock.Label">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button.AddButton">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.AddButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <!-- Underline-style tabs integrated into the card header -->
        <Style Selector="RadioButton.Tab">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid RowDefinitions="*,2">
                        <ContentPresenter Grid.Row="0"
                                          Name="PART_Content"
                                          Content="{TemplateBinding Content}"
                                          Margin="0,0,0,10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        <Rectangle Grid.Row="1" Name="PART_Indicator"
                                   Height="2" Fill="Transparent"
                                   RadiusX="1" RadiusY="1"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,22,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="RadioButton.Tab:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="RadioButton.Tab:checked">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="RadioButton.Tab:checked /template/ Rectangle#PART_Indicator">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColor}"/>
        </Style>

        <!-- ═══ Share Flyout Presenter (Ghost host, same fix as NowPlayingCompact) ═══ -->
        <Style Selector="FlyoutPresenter.ShareFlyout">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ═══ Share Row Button (1:1 clone of SeasonalView FilterToggle) ═══ -->
        <Style Selector="Button.ShareRow">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ShareRow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorSecondary}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.ShareRow:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiary}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <Border Grid.Row="0" Height="34" VerticalAlignment="Top" Background="Transparent" IsHitTestVisible="True" PointerPressed="OnTitleBarPressed" ZIndex="10"/>
        
        <controls:TitleBarButtons Grid.Row="0" Grid.RowSpan="3" HorizontalAlignment="Right" VerticalAlignment="Top" ZIndex="999"/>
        
        <!-- HERO -->
        <Border Grid.Row="0" ClipToBounds="True" Padding="24,34,24,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="{DynamicResource SystemAccentColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource SystemAccentColorDark1}" Offset="0.6"/>
                            <GradientStop Color="{DynamicResource SystemAccentColorDark2}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="Auto, *" VerticalAlignment="Center">
                        <Border Grid.Column="0" Width="100" Height="150" CornerRadius="8" ClipToBounds="True" BoxShadow="0 4 20 0 #60000000">
                            <Image asyncImageLoader:ImageLoader.Source="{Binding Anime.MainPictureUrl}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{Binding Anime.Title}" FontSize="26" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" LineHeight="32"/>
                            <TextBlock Text="{Binding Anime.RussianTitle}" FontSize="14" Foreground="#90FFFFFF" TextWrapping="Wrap">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="Settings.Current.UI.UseRussianTitles"/>
                                        <Binding Path="Anime.RussianTitle" Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <material:MaterialIcon Kind="Star" Width="14" Height="14" Foreground="Gold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Anime.MeanScore}" FontWeight="SemiBold" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Width="1" Height="12" Background="#40FFFFFF" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <material:MaterialIcon Kind="Television" Width="12" Height="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Anime.Type, Converter={StaticResource LocConverter}}" FontSize="11" Foreground="#B0FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Width="1" Height="12" Background="#40FFFFFF" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <material:MaterialIcon Kind="Calendar" Width="12" Height="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Anime.Season, Converter={StaticResource LocConverter}}" FontSize="11" Foreground="#B0FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Width="1" Height="12" Background="#40FFFFFF" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <material:MaterialIcon Kind="TrendingUp" Width="12" Height="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Anime.Popularity, StringFormat='#{0}'}" FontSize="11" Foreground="#B0FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                <Border Background="#20FFFFFF" CornerRadius="6" Width="28" Height="28" ToolTip.Tip="MyAnimeList">
                                    <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#35FFFFFF"/></Style></Border.Styles>
                                    <Button Background="Transparent" Padding="0" CornerRadius="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenMalLinkCommand}">
                                        <Image Source="/Assets/myanimelist_white.png" Width="16" Height="16" Opacity="0.9"/>
                                    </Button>
                                </Border>
                                <Border Background="#20FFFFFF" CornerRadius="6" Width="28" Height="28" ToolTip.Tip="Shikimori">
                                    <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#35FFFFFF"/></Style></Border.Styles>
                                    <Button Background="Transparent" Padding="0" CornerRadius="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenShikiLinkCommand}">
                                        <Image Source="/Assets/shikimori_white.png" Width="16" Height="16" Opacity="0.9"/>
                                    </Button>
                                </Border>
                                <!-- User-defined share buttons (one circular icon per item).
                                     ItemsSource bound to AnimeDetailsViewModel.CustomShareLinks. -->
                                <ItemsControl ItemsSource="{Binding CustomShareLinks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CustomShareLinkRuntime">
                                            <Border Background="#20FFFFFF" CornerRadius="6" Width="28" Height="28" ToolTip.Tip="{Binding Name}">
                                                <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#35FFFFFF"/></Style></Border.Styles>
                                                <Button Background="Transparent" Padding="0" CornerRadius="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenCommand}">
                                                    <Panel>
                                                        <material:MaterialIcon Kind="{Binding IconKind}" Width="16" Height="16" Foreground="#CCFFFFFF"
                                                                               IsVisible="{Binding UseIconKind}"/>
                                                        <Image Source="{Binding IconPath, Converter={StaticResource FilePathToBitmapConverter}}"
                                                               Width="18" Height="18" Stretch="UniformToFill"
                                                               IsVisible="{Binding HasIconImage}"/>
                                                    </Panel>
                                                </Button>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Background="#20FFFFFF" CornerRadius="6" Width="28" Height="28" ToolTip.Tip="{DynamicResource l.common.actions.share}">
                                    <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#35FFFFFF"/></Style></Border.Styles>
                                    <Button x:Name="ShareMainButton" Background="Transparent" Padding="0" CornerRadius="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <material:MaterialIcon Kind="ShareVariant" Width="16" Height="16" Foreground="#CCFFFFFF"/>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedRight" FlyoutPresenterClasses="ShareFlyout">
                                                <!-- Opaque container (same transparency fix as NowPlayingCompact) -->
                                                <Border Background="{DynamicResource ModalBackgroundFill}"
                                                        BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        BoxShadow="0 8 32 0 #30000000">
                                                    <StackPanel Spacing="4" Margin="10">
                                                        <Button Classes="ShareRow" Command="{Binding CopyMalLinkCommand}" Click="ShareRow_Click">
                                                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                        Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                                    <Image Source="/Assets/myanimelist_white.png" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.links.mal}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                            </Grid>
                                                        </Button>
                                                        <Button Classes="ShareRow" Command="{Binding CopyShikiLinkCommand}" Click="ShareRow_Click">
                                                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                        Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                                    <Image Source="/Assets/shikimori_white.png" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.links.shiki}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                            </Grid>
                                                        </Button>
                                                        <Border Height="1" Margin="0,4" Background="{DynamicResource DividerStrokeColorDefault}"
                                                                IsVisible="{Binding CustomShareLinks.Count, Converter={StaticResource IntToBoolConverter}}"/>
                                                        <ItemsControl ItemsSource="{Binding CustomShareLinks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Spacing="4"/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:CustomShareLinkRuntime">
                                                                    <Button Classes="ShareRow" Command="{Binding CopyCommand}" Click="ShareRow_Click">
                                                                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                                    Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                                                <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                    <material:MaterialIcon Kind="{Binding IconKind}" Width="14" Height="14" Foreground="White"
                                                                                                           IsVisible="{Binding UseIconKind}"/>
                                                                                    <Image Source="{Binding IconPath, Converter={StaticResource FilePathToBitmapConverter}}"
                                                                                           Width="14" Height="14" Stretch="UniformToFill"
                                                                                           IsVisible="{Binding HasIconImage}"/>
                                                                                </Panel>
                                                                            </Border>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                        </Grid>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SCROLLABLE CONTENT -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" u:SmoothScroll.IsEnabled="True">
                    <StackPanel Spacing="14" Margin="0,14,0,0">

                <!-- T-SHAPE TOP ROW: Actions & Details -->
                <!-- MAIN CONTENT GRID: 2 Columns -->
                <Grid ColumnDefinitions="*,14,*" Margin="24,0,24,8">
                    
                    <!-- LEFT COLUMN: Quick Actions, Add Button, Alternative Titles -->
                    <StackPanel Grid.Column="0" Spacing="14">
                        <!-- QUICK ACTIONS (in list) -->
                        <Border Classes="ContentCard" IsVisible="{Binding IsInList}" Padding="0">
                            <StackPanel>
                                <!-- Header row with title + compact delete -->
                                <Grid ColumnDefinitions="*, Auto" Margin="18,14,10,10">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Border Width="6" Height="18" CornerRadius="3"
                                                Background="{DynamicResource SystemAccentColor}"/>
                                        <TextBlock Text="{DynamicResource l.anime.list_actions.in_my_list}"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding RemoveFromListCommand}"
                                            CommandParameter="{Binding $parent[Window]}"
                                            Classes.confirm="{Binding IsDeleteConfirmationVisible}"
                                            ToolTip.Tip="{DynamicResource l.anime.list_actions.remove_from_list}"
                                            Padding="8,5" CornerRadius="6"
                                            VerticalAlignment="Center">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="#FF4500"/>
                                                <Setter Property="Opacity" Value="0.75"/>
                                                <Setter Property="Transitions">
                                                    <Transitions>
                                                        <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                                    </Transitions>
                                                </Setter>
                                            </Style>
                                            <Style Selector="Button:pointerover">
                                                <Setter Property="Background" Value="#18FF4500"/>
                                                <Setter Property="Opacity" Value="1"/>
                                            </Style>
                                            <Style Selector="Button.confirm">
                                                <Setter Property="Background" Value="#FF4500"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Opacity" Value="1"/>
                                            </Style>
                                            <Style Selector="Button.confirm:pointerover">
                                                <Setter Property="Background" Value="#FF4500"/>
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Style>
                                        </Button.Styles>
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <material:MaterialIcon Width="15" Height="15" VerticalAlignment="Center"
                                                                   Kind="DeleteOutline"
                                                                   IsVisible="{Binding !IsDeleteConfirmationVisible}"/>
                                            <material:MaterialIcon Width="15" Height="15" VerticalAlignment="Center"
                                                                   Kind="AlertOutline"
                                                                   IsVisible="{Binding IsDeleteConfirmationVisible}"/>
                                            <TextBlock Text="{DynamicResource l.anime.list_actions.confirm_delete}"
                                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                                       IsVisible="{Binding IsDeleteConfirmationVisible}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefault}" Opacity="0.6"/>

                                <StackPanel Margin="18,16,18,16" Spacing="16">
                                    <!-- PROGRESS block -->
                                    <StackPanel Spacing="8">
                                        <!-- Episodes (Anime) -->
                                        <StackPanel Spacing="8" IsVisible="{Binding Anime.IsAnime}">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0" Text="{DynamicResource l.anime.labels.watched_episodes}" Classes="FieldLabel" Margin="0"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Anime.Progress}" FontSize="16" FontWeight="Bold"
                                                               Foreground="{DynamicResource SystemAccentColor}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="из" FontSize="13" Opacity="0.35" VerticalAlignment="Center" Margin="4,0"/>
                                                    <TextBlock Text="{Binding Anime.TotalEpisodes}" FontSize="13" Opacity="0.55" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                                <ProgressBar Grid.Column="0" Minimum="0"
                                                             Maximum="{Binding Anime.TotalEpisodes}"
                                                             Value="{Binding Anime.Progress}"
                                                             Height="6" MinHeight="6" CornerRadius="3"
                                                             VerticalAlignment="Center"/>
                                                <NumericUpDown Grid.Column="1" Value="{Binding Anime.Progress}"
                                                               Minimum="0" Maximum="{Binding Anime.TotalEpisodes}"
                                                               Width="70" ShowButtonSpinner="False" CornerRadius="6" FontSize="12"/>
                                                <Button Grid.Column="2" Command="{Binding IncrementProgressCommand}"
                                                        ToolTip.Tip="+1"
                                                        Width="32" Height="32" Padding="0" CornerRadius="6"
                                                        Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                                        BorderThickness="0">
                                                    <material:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Chapters & Volumes (Manga) -->
                                        <StackPanel Spacing="16" IsVisible="{Binding Anime.IsManga}">
                                            <!-- Chapters -->
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <TextBlock Grid.Column="0" Text="{DynamicResource l.anime.labels.chapters}" Classes="FieldLabel" Margin="0"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Anime.ChaptersRead}" FontSize="16" FontWeight="Bold"
                                                                   Foreground="{DynamicResource SystemAccentColor}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="из" FontSize="13" Opacity="0.35" VerticalAlignment="Center" Margin="4,0"/>
                                                        <TextBlock Text="{Binding Anime.Chapters}" FontSize="13" Opacity="0.55" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                                    <ProgressBar Grid.Column="0" Minimum="0"
                                                                 Maximum="{Binding Anime.Chapters}"
                                                                 Value="{Binding Anime.ChaptersRead}"
                                                                 Height="6" MinHeight="6" CornerRadius="3"
                                                                 VerticalAlignment="Center"/>
                                                    <NumericUpDown Grid.Column="1" Value="{Binding Anime.ChaptersRead}"
                                                                   Minimum="0" Maximum="{Binding Anime.Chapters}"
                                                                   Width="70" ShowButtonSpinner="False" CornerRadius="6" FontSize="12"/>
                                                    <Button Grid.Column="2" Command="{Binding IncrementProgressCommand}"
                                                            ToolTip.Tip="+1"
                                                            Width="32" Height="32" Padding="0" CornerRadius="6"
                                                            Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                                            BorderThickness="0">
                                                        <material:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Volumes -->
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <TextBlock Grid.Column="0" Text="{DynamicResource l.anime.labels.volumes}" Classes="FieldLabel" Margin="0"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Anime.VolumesRead}" FontSize="16" FontWeight="Bold"
                                                                   Foreground="{DynamicResource SystemAccentColor}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="из" FontSize="13" Opacity="0.35" VerticalAlignment="Center" Margin="4,0"/>
                                                        <TextBlock Text="{Binding Anime.Volumes}" FontSize="13" Opacity="0.55" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                                    <ProgressBar Grid.Column="0" Minimum="0"
                                                                 Maximum="{Binding Anime.Volumes}"
                                                                 Value="{Binding Anime.VolumesRead}"
                                                                 Height="6" MinHeight="6" CornerRadius="3"
                                                                 VerticalAlignment="Center"/>
                                                    <NumericUpDown Grid.Column="1" Value="{Binding Anime.VolumesRead}"
                                                                   Minimum="0" Maximum="{Binding Anime.Volumes}"
                                                                   Width="70" ShowButtonSpinner="False" CornerRadius="6" FontSize="12"/>
                                                    <Button Grid.Column="2" Command="{Binding IncrementVolumesCommand}"
                                                            ToolTip.Tip="+1"
                                                            Width="32" Height="32" Padding="0" CornerRadius="6"
                                                            Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                                            BorderThickness="0">
                                                        <material:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- STATUS | SCORE (2 columns) + Rewatch -->
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,10,*">
                                            <!-- STATUS -->
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Text="{DynamicResource l.anime.labels.status}" Classes="FieldLabel" Margin="0"/>
                                                <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                                          SelectedItem="{Binding Anime.Status}"
                                                          CornerRadius="6" HorizontalAlignment="Stretch" FontSize="12">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding, Converter={StaticResource LocConverter}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- SCORE -->
                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <TextBlock Text="{DynamicResource l.anime.labels.your_score}" Classes="FieldLabel" Margin="0"/>
                                                <ComboBox ItemsSource="{Binding AvailableScores}"
                                                          SelectedItem="{Binding Anime.Score, Converter={StaticResource RatingConverter}}"
                                                          CornerRadius="6" HorizontalAlignment="Stretch" FontSize="12">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="models:RatingOption">
                                                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <CheckBox Content="{DynamicResource l.anime.status.rewatching}"
                                                  IsChecked="{Binding Anime.IsRewatching}"
                                                  FontSize="11" Opacity="0.7" Padding="6,0,0,0"
                                                  HorizontalAlignment="Left" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ADD TO LIST (not in list) -->
                        <Border IsVisible="{Binding !IsInList}">
                            <Button Classes="AddButton" Command="{Binding AddToListCommand}" HorizontalAlignment="Stretch">
                                <Grid ColumnDefinitions="Auto, Auto" HorizontalAlignment="Center">
                                    <material:MaterialIcon Grid.Column="0" Kind="PlaylistPlus" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.list_actions.add_to_list}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </Border>

                        <!-- RELATIONS -->
                        <Border Classes="ContentCard" IsVisible="{Binding Relations.Count, Converter={StaticResource IntToBoolConverter}}">
                            <StackPanel>
                                <TextBlock Text="Связанное" Classes="SectionTitle"/>
                                <ItemsControl ItemsSource="{Binding Relations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RelationItemVm">
                                            <Button Classes="Flat" HorizontalAlignment="Stretch" Padding="8" Margin="0,0,0,4"
                                                    Command="{Binding #Root.((vm:AnimeDetailsViewModel)DataContext).NavigateToRelationCommand}"
                                                    CommandParameter="{Binding Relation}">
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <!-- Image -->
                                                    <Border Grid.Column="0" Width="40" Height="56" CornerRadius="4" Margin="0,0,12,0" ClipToBounds="True">
                                                        <Panel>
                                                            <Border Background="{DynamicResource CardBackgroundBrush}"/>
                                                            <Image asyncImageLoader:ImageLoader.Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                        </Panel>
                                                    </Border>
                                                    
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Relation.TargetName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Relation.RelationType}" FontSize="12" Opacity="0.7"/>
                                                    </StackPanel>
                                                    
                                                    <Border Grid.Column="2" Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" IsVisible="{Binding Relation.TargetType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Text="{Binding Relation.TargetType}" FontSize="11" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- STAFF -->
                        <Border Classes="ContentCard" IsVisible="{Binding Staff.Count, Converter={StaticResource IntToBoolConverter}}">
                            <StackPanel>
                                <TextBlock Text="Персонал" Classes="SectionTitle"/>
                                <ItemsControl ItemsSource="{Binding Staff}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:StaffItemVm">
                                            <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <!-- Image -->
                                                    <Border Grid.Column="0" Width="40" Height="56" CornerRadius="4" Margin="0,0,12,0" ClipToBounds="True">
                                                        <Panel>
                                                            <Border Background="{DynamicResource CardBackgroundBrush}"/>
                                                            <Image asyncImageLoader:ImageLoader.Source="{Binding Staff.PersonImageUrl}" Stretch="UniformToFill" IsVisible="{Binding Staff.PersonImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                            <material:MaterialIcon Kind="Account" Width="24" Height="24" Opacity="0.5" IsVisible="{Binding Staff.PersonImageUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                        </Panel>
                                                    </Border>
                                                    
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Staff.PersonName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Staff.Positions}" FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- RIGHT COLUMN: Tabbed info card (Details / Synopsis / Alt titles) -->
                    <Border Grid.Column="2" Classes="ContentCard" Padding="0" VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Tabs header -->
                            <Border BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                    BorderThickness="0,0,0,1"
                                    Padding="18,12,18,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="TabDetails" Classes="Tab" GroupName="DetailsTab"
                                                 IsChecked="True"
                                                 Content="{DynamicResource l.common.actions.details}"/>
                                    <RadioButton x:Name="TabSynopsis" Classes="Tab" GroupName="DetailsTab"
                                                 Content="{DynamicResource l.anime.labels.synopsis}"/>
                                    <RadioButton x:Name="TabAltTitles" Classes="Tab" GroupName="DetailsTab"
                                                 Content="{DynamicResource l.anime.labels.alternative_titles}"/>
                                </StackPanel>
                            </Border>

                            <Panel Margin="18,16,18,16">
                                <!-- Details -->
                                <Grid IsVisible="{Binding #TabDetails.IsChecked}"
                                      Classes="DetailsGrid" ColumnDefinitions="Auto, *"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="3">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource l.anime.labels.status}" Classes="Label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Anime.DisplayAiringStatus}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource l.anime.labels.episodes}" Classes="Label" IsVisible="{Binding Anime.IsAnime}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Anime.EpisodesDisplay}" IsVisible="{Binding Anime.IsAnime}"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource l.anime.labels.chapters}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Anime.ChaptersDisplay}" IsVisible="{Binding Anime.IsManga}"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource l.anime.labels.volumes}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Anime.VolumesDisplay}" IsVisible="{Binding Anime.IsManga}"/>
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource l.anime.labels.aired_episodes}" Classes="Label">
                                        <TextBlock.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="Settings.Current.UI.ShowAiringInfo"/><Binding Path="Anime.ShowAiredInfo"/></MultiBinding></TextBlock.IsVisible>
                                    </TextBlock>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Anime, Converter={StaticResource LocConverter}, ConverterParameter='format:l.anime.labels.aired_format'}">
                                        <TextBlock.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="Settings.Current.UI.ShowAiringInfo"/><Binding Path="Anime.ShowAiredInfo"/></MultiBinding></TextBlock.IsVisible>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource l.anime.labels.next_episode}" Classes="Label" IsVisible="{Binding Anime.NextEpisodeAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Anime.NextEpisodeAtDisplay}" IsVisible="{Binding Anime.NextEpisodeAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource l.anime.labels.genres}" Classes="Label"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Anime.Genres, Converter={StaticResource LocConverter}}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource l.anime.labels.studios}" Classes="Label" IsVisible="{Binding Anime.IsAnime}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource l.anime.labels.authors}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Anime.Studios, Converter={StaticResource LocConverter}}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource l.anime.labels.score}" Classes="Label"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Anime.MeanScore}"/>
                                </Grid>

                                <!-- Synopsis -->
                                <StackPanel IsVisible="{Binding #TabSynopsis.IsChecked}">
                                    <TextBlock Text="{Binding Anime.DisplaySynopsis}" TextWrapping="Wrap" Opacity="0.8" LineHeight="20" FontSize="13"/>
                                    <TextBlock Text="{DynamicResource l.anime.labels.no_synopsis}" FontSize="13" Opacity="0.5" IsVisible="{Binding Anime.DisplaySynopsis, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                </StackPanel>

                                <!-- Alt titles -->
                                <StackPanel IsVisible="{Binding #TabAltTitles.IsChecked}">
                                    <ItemsControl ItemsSource="{Binding AllAlternativeTitles}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="6" Padding="10,5" Margin="0,0,8,6">
                                                    <TextBlock Text="{Binding}" FontSize="12" Opacity="0.75"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{DynamicResource l.anime.labels.no_alternative_titles}" FontSize="13" Opacity="0.5" IsVisible="{Binding !HasAlternativeTitles}"/>
                                </StackPanel>
                            </Panel>
                        </StackPanel>
                    </Border>
                </Grid>
                    
            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="2" Padding="24,8,24,16" Background="{DynamicResource LayerFillColorDefault}" BorderBrush="{DynamicResource DividerStrokeColorDefault}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="{DynamicResource l.common.actions.confirm}" IsDefault="True" Width="100" Height="36" Background="{DynamicResource SystemAccentColor}" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="8" FontWeight="SemiBold" FontSize="12" Command="{Binding SaveCommand}" CommandParameter="{Binding $parent[Window]}"/>
                <Button Content="{DynamicResource l.common.actions.cancel}" IsCancel="True" Width="100" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="8" FontSize="12" Background="{DynamicResource SubtleFillColorSecondary}" BorderThickness="0" Command="{Binding $parent[Window].Close}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
