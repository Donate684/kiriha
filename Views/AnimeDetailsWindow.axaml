<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiriha.ViewModels"
        xmlns:models="using:Kiriha.Models"
        xmlns:entities="using:Kiriha.Models.Entities"
        xmlns:controls="using:Kiriha.Views.Controls"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:conv="using:Kiriha.Converters"
        xmlns:u="using:Kiriha.Utils"
        x:Class="Kiriha.Views.AnimeDetailsWindow"
        x:DataType="vm:AnimeDetailsViewModel"
        x:Name="Root"
        Title=""
        Width="920" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{x:Null}"
        TransparencyLevelHint="Mica, AcrylicBlur"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="34"
        WindowDecorations="BorderOnly">

    <Window.Resources>
        <conv:LocConverter x:Key="LocConverter"/>
        <conv:RatingConverter x:Key="RatingConverter"/>
        <conv:FilePathToBitmapConverter x:Key="FilePathToBitmapConverter"/>
        <conv:IntToBooleanConverter x:Key="IntToBoolConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Modern Card Style -->
        <Style Selector="Border.ContentCard">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillDefault}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 4 16 0 #0A000000"/>
        </Style>
        <Style Selector="Border.ContentCard:pointerover">
            <Setter Property="BoxShadow" Value="0 6 20 0 #0F000000"/>
        </Style>

        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > Control">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > TextBlock">
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Grid.DetailsGrid > TextBlock.Label">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button.AddButton">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.AddButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.01)"/>
            <Setter Property="Opacity" Value="0.95"/>
        </Style>

        <!-- Underline-style tabs integrated into the card header -->
        <Style Selector="RadioButton.Tab">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid RowDefinitions="*,3">
                        <ContentPresenter Grid.Row="0"
                                          Name="PART_Content"
                                          Content="{TemplateBinding Content}"
                                          Margin="0,0,0,12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        <Rectangle Grid.Row="1" Name="PART_Indicator"
                                   Height="3" Fill="Transparent"
                                   RadiusX="1.5" RadiusY="1.5"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="RadioButton.Tab:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="RadioButton.Tab:checked">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="RadioButton.Tab:checked /template/ Rectangle#PART_Indicator">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColor}"/>
        </Style>

        <!-- Share Flyout -->
        <Style Selector="FlyoutPresenter.ShareFlyout">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Share Row Button -->
        <Style Selector="Button.ShareRow">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ShareRow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorSecondary}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>

        <!-- Sidebar field label -->
        <Style Selector="TextBlock.SidebarLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- ComboBox custom styling for modern look -->
        <Style Selector="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- Relation/Staff Buttons -->
        <Style Selector="Button.RelationCardButton">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillDefault}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.RelationCardButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Height="34" VerticalAlignment="Top" Background="Transparent" IsHitTestVisible="True" PointerPressed="OnTitleBarPressed" ZIndex="10"/>
        
        <controls:TitleBarButtons Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" ZIndex="999"/>
        
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- HERO BANNER                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" ClipToBounds="True" Padding="28,40,28,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="{DynamicResource SystemAccentColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource SystemAccentColorDark1}" Offset="0.6"/>
                    <GradientStop Color="{DynamicResource SystemAccentColorDark2}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto, *" VerticalAlignment="Center">
                <Border Grid.Column="0" Width="105" Height="152" CornerRadius="10" ClipToBounds="True" BoxShadow="0 8 24 0 #40000000">
                    <Image asyncImageLoader:ImageLoader.Source="{Binding Anime.MainPictureUrl}" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding Anime.Title}" FontSize="28" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" LineHeight="34"/>
                    <TextBlock Text="{Binding Anime.RussianTitle}" FontSize="15" Foreground="#BFFFFFFF" TextWrapping="Wrap">
                        <TextBlock.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="Settings.Current.UI.UseRussianTitles"/>
                                <Binding Path="Anime.RussianTitle" Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                            </MultiBinding>
                        </TextBlock.IsVisible>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <material:MaterialIcon Kind="Star" Width="14" Height="14" Foreground="Gold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Anime.MeanScore}" FontWeight="SemiBold" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="12" Background="#30FFFFFF" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <material:MaterialIcon Kind="Television" Width="12" Height="12" Foreground="#A0FFFFFF" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Anime.Type, Converter={StaticResource LocConverter}}" FontSize="12" Foreground="#D0FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="12" Background="#30FFFFFF" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <material:MaterialIcon Kind="Calendar" Width="12" Height="12" Foreground="#A0FFFFFF" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Anime.Season, Converter={StaticResource LocConverter}}" FontSize="12" Foreground="#D0FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="12" Background="#30FFFFFF" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <material:MaterialIcon Kind="TrendingUp" Width="12" Height="12" Foreground="#A0FFFFFF" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Anime.Popularity, StringFormat='#{0}'}" FontSize="12" Foreground="#D0FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Action Row Links -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,10,0,0">
                        <Border Background="#25FFFFFF" CornerRadius="8" Width="30" Height="30" ToolTip.Tip="MyAnimeList">
                            <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#40FFFFFF"/></Style></Border.Styles>
                            <Button Background="Transparent" Padding="0" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenMalLinkCommand}">
                                <Image Source="/Assets/myanimelist_white.png" Width="16" Height="16" Opacity="0.95"/>
                            </Button>
                        </Border>
                        <Border Background="#25FFFFFF" CornerRadius="8" Width="30" Height="30" ToolTip.Tip="Shikimori">
                            <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#40FFFFFF"/></Style></Border.Styles>
                            <Button Background="Transparent" Padding="0" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenShikiLinkCommand}">
                                <Image Source="/Assets/shikimori_white.png" Width="16" Height="16" Opacity="0.95"/>
                            </Button>
                        </Border>
                        <!-- User Share links -->
                        <ItemsControl ItemsSource="{Binding CustomShareLinks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CustomShareLinkRuntime">
                                    <Border Background="#25FFFFFF" CornerRadius="8" Width="30" Height="30" ToolTip.Tip="{Binding Name}">
                                        <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#40FFFFFF"/></Style></Border.Styles>
                                        <Button Background="Transparent" Padding="0" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding OpenCommand}">
                                            <Panel>
                                                <material:MaterialIcon Kind="{Binding IconKind}" Width="16" Height="16" Foreground="White"
                                                                       IsVisible="{Binding UseIconKind}"/>
                                                <Image Source="{Binding IconPath, Converter={StaticResource FilePathToBitmapConverter}}"
                                                       Width="18" Height="18" Stretch="UniformToFill"
                                                       IsVisible="{Binding HasIconImage}"/>
                                            </Panel>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Border Background="#25FFFFFF" CornerRadius="8" Width="30" Height="30" ToolTip.Tip="{DynamicResource l.common.actions.share}">
                            <Border.Styles><Style Selector="Border:pointerover"><Setter Property="Background" Value="#40FFFFFF"/></Style></Border.Styles>
                            <Button x:Name="ShareMainButton" Background="Transparent" Padding="0" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <material:MaterialIcon Kind="ShareVariant" Width="16" Height="16" Foreground="White"/>
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight" FlyoutPresenterClasses="ShareFlyout">
                                        <Border Background="{DynamicResource ModalBackgroundFill}"
                                                BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                BoxShadow="0 8 32 0 #30000000">
                                            <StackPanel Spacing="4" Margin="10">
                                                <Button Classes="ShareRow" Command="{Binding CopyMalLinkCommand}" Click="ShareRow_Click">
                                                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                            <Image Source="/Assets/myanimelist_white.png" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.links.mal}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                </Button>
                                                <Button Classes="ShareRow" Command="{Binding CopyShikiLinkCommand}" Click="ShareRow_Click">
                                                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                            <Image Source="/Assets/shikimori_white.png" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.links.shiki}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                </Button>
                                                <Border Height="1" Margin="0,4" Background="{DynamicResource DividerStrokeColorDefault}"
                                                        IsVisible="{Binding CustomShareLinks.Count, Converter={StaticResource IntToBoolConverter}}"/>
                                                <ItemsControl ItemsSource="{Binding CustomShareLinks}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Spacing="4"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:CustomShareLinkRuntime">
                                                            <Button Classes="ShareRow" Command="{Binding CopyCommand}" Click="ShareRow_Click">
                                                                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                                            Background="{DynamicResource SystemAccentColor}" VerticalAlignment="Center">
                                                                        <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <material:MaterialIcon Kind="{Binding IconKind}" Width="14" Height="14" Foreground="White"
                                                                                                   IsVisible="{Binding UseIconKind}"/>
                                                                            <Image Source="{Binding IconPath, Converter={StaticResource FilePathToBitmapConverter}}"
                                                                                   Width="14" Height="14" Stretch="UniformToFill"
                                                                                   IsVisible="{Binding HasIconImage}"/>
                                                                        </Panel>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA: Sidebar (290px) + Main Content (*)                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="290, *">

            <!-- ─────────────────────── SIDEBAR ─────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource LayerFillColorDefault}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefault}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,18,24,20" Spacing="16">

                        <!-- ══ IN LIST: User editing controls ══ -->
                        <StackPanel IsVisible="{Binding IsInList}" Spacing="14">

                            <!-- Header: "В моём списке" + Delete -->
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="4" Height="16" CornerRadius="2"
                                            Background="{DynamicResource SystemAccentColor}"/>
                                    <TextBlock Text="{DynamicResource l.anime.list_actions.in_my_list}"
                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding RemoveFromListCommand}"
                                        CommandParameter="{Binding $parent[Window]}"
                                        Classes.confirm="{Binding IsDeleteConfirmationVisible}"
                                        ToolTip.Tip="{DynamicResource l.anime.list_actions.remove_from_list}"
                                        Padding="6" CornerRadius="6"
                                        VerticalAlignment="Center">
                                    <Button.Styles>
                                        <Style Selector="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="#FF4500"/>
                                            <Setter Property="Opacity" Value="0.75"/>
                                            <Setter Property="Transitions">
                                                <Transitions>
                                                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                                </Transitions>
                                            </Setter>
                                        </Style>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#15FF4500"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </Style>
                                        <Style Selector="Button.confirm">
                                            <Setter Property="Background" Value="#FF4500"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </Style>
                                    </Button.Styles>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <material:MaterialIcon Width="16" Height="16" VerticalAlignment="Center"
                                                               Kind="DeleteOutline"
                                                               IsVisible="{Binding !IsDeleteConfirmationVisible}"/>
                                        <material:MaterialIcon Width="16" Height="16" VerticalAlignment="Center"
                                                               Kind="AlertOutline"
                                                               IsVisible="{Binding IsDeleteConfirmationVisible}"/>
                                        <TextBlock Text="{DynamicResource l.anime.list_actions.confirm_delete}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                                   IsVisible="{Binding IsDeleteConfirmationVisible}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource DividerStrokeColorDefault}" Opacity="0.5" Margin="0,-4,0,0"/>

                            <!-- STATUS -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource l.anime.labels.status}" Classes="SidebarLabel"/>
                                <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                          SelectedItem="{Binding Anime.Status}"
                                          HorizontalAlignment="Stretch" FontSize="12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding, Converter={StaticResource LocConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- SCORE -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource l.anime.labels.your_score}" Classes="SidebarLabel"/>
                                <ComboBox ItemsSource="{Binding AvailableScores}"
                                          SelectedItem="{Binding Anime.Score, Converter={StaticResource RatingConverter}}"
                                          HorizontalAlignment="Stretch" FontSize="12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:RatingOption">
                                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- PROGRESS: Episodes (Anime) -->
                            <StackPanel Spacing="6" IsVisible="{Binding Anime.IsAnime}">
                                <TextBlock Text="{DynamicResource l.anime.labels.watched_episodes}" Classes="SidebarLabel"/>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                    <NumericUpDown Grid.Column="0" Value="{Binding Anime.Progress}"
                                                   Minimum="0" Maximum="{Binding Anime.TotalEpisodes}"
                                                   Width="110" Height="32" ShowButtonSpinner="True" 
                                                   CornerRadius="6" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                                        <TextBlock Text="из" FontSize="12" Opacity="0.4"/>
                                        <TextBlock Text="{Binding Anime.TotalEpisodes}" FontSize="13" Opacity="0.7" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2" Command="{Binding IncrementProgressCommand}"
                                            ToolTip.Tip="+1"
                                            Width="32" Height="32" Padding="0" CornerRadius="6"
                                            Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                            BorderThickness="0" VerticalAlignment="Center">
                                        <material:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                                <ProgressBar Minimum="0"
                                             Maximum="{Binding Anime.TotalEpisodes}"
                                             Value="{Binding Anime.Progress}"
                                             Height="4" MinHeight="4" CornerRadius="2"
                                             Foreground="{DynamicResource SystemAccentColor}"
                                             Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- PROGRESS: Chapters & Volumes (Manga) -->
                            <StackPanel Spacing="12" IsVisible="{Binding Anime.IsManga}">
                                <!-- Chapters -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{DynamicResource l.anime.labels.chapters}" Classes="SidebarLabel"/>
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                        <NumericUpDown Grid.Column="0" Value="{Binding Anime.ChaptersRead}"
                                                       Minimum="0" Maximum="{Binding Anime.Chapters}"
                                                       Width="110" Height="32" ShowButtonSpinner="True" 
                                                       CornerRadius="6" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                                            <TextBlock Text="из" FontSize="12" Opacity="0.4"/>
                                            <TextBlock Text="{Binding Anime.Chapters}" FontSize="13" Opacity="0.7" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Command="{Binding IncrementProgressCommand}"
                                                ToolTip.Tip="+1"
                                                Width="32" Height="32" Padding="0" CornerRadius="6"
                                                Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                                BorderThickness="0" VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                    <ProgressBar Minimum="0"
                                                 Maximum="{Binding Anime.Chapters}"
                                                 Value="{Binding Anime.ChaptersRead}"
                                                 Height="4" MinHeight="4" CornerRadius="2"
                                                 Foreground="{DynamicResource SystemAccentColor}"
                                                 Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- Volumes -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{DynamicResource l.anime.labels.volumes}" Classes="SidebarLabel"/>
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                        <NumericUpDown Grid.Column="0" Value="{Binding Anime.VolumesRead}"
                                                       Minimum="0" Maximum="{Binding Anime.Volumes}"
                                                       Width="110" Height="32" ShowButtonSpinner="True" 
                                                       CornerRadius="6" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                                            <TextBlock Text="из" FontSize="12" Opacity="0.4"/>
                                            <TextBlock Text="{Binding Anime.Volumes}" FontSize="13" Opacity="0.7" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Command="{Binding IncrementVolumesCommand}"
                                                ToolTip.Tip="+1"
                                                Width="32" Height="32" Padding="0" CornerRadius="6"
                                                Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                                BorderThickness="0" VerticalAlignment="Center">
                                            <material:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                    <ProgressBar Minimum="0"
                                                 Maximum="{Binding Anime.Volumes}"
                                                 Value="{Binding Anime.VolumesRead}"
                                                 Height="4" MinHeight="4" CornerRadius="2"
                                                 Foreground="{DynamicResource SystemAccentColor}"
                                                 Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- REWATCHING -->
                            <CheckBox Content="{DynamicResource l.anime.status.rewatching}"
                                      IsChecked="{Binding Anime.IsRewatching}"
                                      FontSize="12" Opacity="0.85" Padding="8,0,0,0"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- ══ NOT IN LIST: Add to List button ══ -->
                        <StackPanel IsVisible="{Binding !IsInList}" Spacing="0">
                            <Button Classes="AddButton" Command="{Binding AddToListCommand}" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                                <Grid ColumnDefinitions="Auto, Auto" HorizontalAlignment="Center">
                                    <material:MaterialIcon Grid.Column="0" Kind="PlaylistPlus" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource l.anime.list_actions.add_to_list}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <!-- Save changes button inside Sidebar -->
                        <Button Command="{Binding SaveCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                HorizontalAlignment="Stretch"
                                Margin="0,-12,0,0"
                                Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource SystemAccentColor}"
                                BorderThickness="0"
                                Foreground="White">
                            <Button.Styles>
                                <Style Selector="Button:disabled">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefault}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefault}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabled}"/>
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Style>
                            </Button.Styles>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                <material:MaterialIcon Kind="Check" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource l.common.actions.confirm}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─────────────────────── MAIN CONTENT ─────────────────────── -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" u:SmoothScroll.IsEnabled="True">
                <StackPanel Spacing="16" Margin="24,18,28,24">

                    <!-- ══ TABBED INFO CARD (Details / Synopsis / Alt Titles) ══ -->
                    <Border Classes="ContentCard" Padding="0">
                        <StackPanel>
                            <!-- Tabs header -->
                            <Border BorderBrush="{DynamicResource CardStrokeColorDefault}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,14,20,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="TabDetails" Classes="Tab" GroupName="DetailsTab"
                                                 IsChecked="True"
                                                 Content="{DynamicResource l.common.actions.details}"/>
                                    <RadioButton x:Name="TabSynopsis" Classes="Tab" GroupName="DetailsTab"
                                                 Content="{DynamicResource l.anime.labels.synopsis}"/>
                                    <RadioButton x:Name="TabAltTitles" Classes="Tab" GroupName="DetailsTab"
                                                 Content="{DynamicResource l.anime.labels.alternative_titles}"/>
                                </StackPanel>
                            </Border>

                            <Panel Margin="20,16">
                                <!-- Details -->
                                <Grid IsVisible="{Binding #TabDetails.IsChecked}"
                                      Classes="DetailsGrid" ColumnDefinitions="Auto, *"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource l.anime.labels.status}" Classes="Label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Anime.DisplayAiringStatus}" FontWeight="Medium"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource l.anime.labels.episodes}" Classes="Label" IsVisible="{Binding Anime.IsAnime}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Anime.EpisodesDisplay}" IsVisible="{Binding Anime.IsAnime}"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource l.anime.labels.chapters}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Anime.ChaptersDisplay}" IsVisible="{Binding Anime.IsManga}"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource l.anime.labels.volumes}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Anime.VolumesDisplay}" IsVisible="{Binding Anime.IsManga}"/>
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource l.anime.labels.aired_episodes}" Classes="Label">
                                        <TextBlock.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="Settings.Current.UI.ShowAiringInfo"/><Binding Path="Anime.ShowAiredInfo"/></MultiBinding></TextBlock.IsVisible>
                                    </TextBlock>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Anime, Converter={StaticResource LocConverter}, ConverterParameter='format:l.anime.labels.aired_format'}">
                                        <TextBlock.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="Settings.Current.UI.ShowAiringInfo"/><Binding Path="Anime.ShowAiredInfo"/></MultiBinding></TextBlock.IsVisible>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource l.anime.labels.next_episode}" Classes="Label" IsVisible="{Binding Anime.NextEpisodeAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Anime.NextEpisodeAtDisplay}" IsVisible="{Binding Anime.NextEpisodeAt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource l.anime.labels.genres}" Classes="Label"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Anime.Genres, Converter={StaticResource LocConverter}}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource l.anime.labels.studios}" Classes="Label" IsVisible="{Binding Anime.IsAnime}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource l.anime.labels.authors}" Classes="Label" IsVisible="{Binding Anime.IsManga}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Anime.Studios, Converter={StaticResource LocConverter}}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource l.anime.labels.score}" Classes="Label"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Anime.MeanScore}"/>
                                </Grid>

                                <!-- Synopsis -->
                                <StackPanel IsVisible="{Binding #TabSynopsis.IsChecked}">
                                    <TextBlock Text="{Binding Anime.DisplaySynopsis}" TextWrapping="Wrap" Opacity="0.85" LineHeight="22" FontSize="13"/>
                                    <TextBlock Text="{DynamicResource l.anime.labels.no_synopsis}" FontSize="13" Opacity="0.5" IsVisible="{Binding Anime.DisplaySynopsis, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                </StackPanel>

                                <!-- Alt titles -->
                                <StackPanel IsVisible="{Binding #TabAltTitles.IsChecked}">
                                    <ItemsControl ItemsSource="{Binding AllAlternativeTitles}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="8" Padding="10,6" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding}" FontSize="12" Opacity="0.8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{DynamicResource l.anime.labels.no_alternative_titles}" FontSize="13" Opacity="0.5" IsVisible="{Binding !HasAlternativeTitles}"/>
                                </StackPanel>
                            </Panel>
                        </StackPanel>
                    </Border>

                    <!-- ══ RELATIONS ══ -->
                    <Border Classes="ContentCard" IsVisible="{Binding Relations.Count, Converter={StaticResource IntToBoolConverter}}">
                        <StackPanel>
                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                                <TextBlock Grid.Column="0" Text="Связанное" Classes="SectionTitle" Margin="0" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Граф франшизы" Command="{Binding ShowFranchiseGraphCommand}" 
                                        FontSize="11" Padding="10,5" CornerRadius="6" 
                                        Background="{DynamicResource SubtleFillColorSecondary}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Relations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RelationItemVm">
                                        <Button Classes="RelationCardButton" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                                Command="{Binding #Root.((vm:AnimeDetailsViewModel)DataContext).NavigateToRelationCommand}"
                                                CommandParameter="{Binding Relation}">
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <!-- Image -->
                                                <Border Grid.Column="0" Width="42" Height="58" CornerRadius="6" Margin="0,0,12,0" ClipToBounds="True">
                                                    <Panel>
                                                        <Border Background="{DynamicResource CardBackgroundBrush}"/>
                                                        <Image asyncImageLoader:ImageLoader.Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                    </Panel>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Relation.TargetName}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="13"/>
                                                    <TextBlock Text="{Binding Relation.RelationType}" FontSize="11" Opacity="0.6" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <Border Grid.Column="2" Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding DisplayTargetType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <TextBlock Text="{Binding DisplayTargetType}" FontSize="10" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ══ STAFF+ ══ -->
                    <Border Classes="ContentCard" IsVisible="{Binding StaffPlus.Count, Converter={StaticResource IntToBoolConverter}}">
                        <StackPanel>
                            <TextBlock Text="Персонал" Classes="SectionTitle"/>
                            <ItemsControl ItemsSource="{Binding StaffPlus}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StaffPlusItemVm">
                                        <Border Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="10" Padding="12" Margin="0,0,10,10" Width="285">
                                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, *">
                                                <!-- Image -->
                                                <Border Grid.RowSpan="2" Grid.Column="0" Width="56" Height="80" CornerRadius="6" Margin="0,0,12,0" ClipToBounds="True" VerticalAlignment="Top">
                                                    <Panel>
                                                        <Border Background="{DynamicResource CardBackgroundBrush}"/>
                                                        <Image asyncImageLoader:ImageLoader.Source="{Binding Staff.PersonImageUrl}" Stretch="UniformToFill" IsVisible="{Binding Staff.PersonImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                        <material:MaterialIcon Kind="Account" Width="28" Height="28" Opacity="0.5" IsVisible="{Binding Staff.PersonImageUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                    </Panel>
                                                </Border>
                                                <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding Staff.PersonName}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="13"/>
                                                    <TextBlock Text="{Binding Role}" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <!-- Best Works -->
                                                <ScrollViewer Grid.Row="1" Grid.Column="1" MaxHeight="100" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding BestWorks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:StaffWorkVm">
                                                                <Border Background="{Binding HighlightColor}" CornerRadius="6" Padding="6,3" Margin="0,0,4,4">
                                                                    <Grid ColumnDefinitions="*, Auto" MaxWidth="170">
                                                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="10.5" TextTrimming="CharacterEllipsis" Opacity="0.8" ToolTip.Tip="{Binding Title}"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Score}" FontSize="10.5" FontWeight="Bold" Margin="4,0,0,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
