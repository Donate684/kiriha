<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiriha.ViewModels"
             xmlns:models="using:Kiriha.Models"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:conv="using:Kiriha.Converters"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:core="using:Kiriha.Core"
             xmlns:u="using:Kiriha.Utils"
             xmlns:controls="using:Kiriha.Views.Controls"
             x:Class="Kiriha.Views.AnimeListView"
             x:DataType="vm:AnimeListViewModel"
             x:CompileBindings="True"
             x:Name="animeListRoot">

    <UserControl.Resources>
        <conv:LocConverter x:Key="LocConverter"/>



        <!-- ═══════════ VARIANT F: Floating Magazine ═══════════ -->
        <DataTemplate x:Key="CardTemplateFloatingMagazine" x:DataType="models:AnimeItem">
            <Border Classes="AnimeCard revealItem FloatingMagCard" Margin="4" Width="158" Height="325" ClipToBounds="False"
                    CornerRadius="10" Background="{DynamicResource CardBackgroundFillSecondary}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefault}" BorderThickness="1">
                <Border CornerRadius="10" ClipToBounds="True">
                    <Grid RowDefinitions="210, *">
                    <!-- Poster -->
                    <Panel Grid.Row="0" Background="Transparent" DoubleTapped="Poster_DoubleTapped">
                        <Image core:CachedImage.Source="{Binding MainPictureUrl}" Stretch="UniformToFill"/>

                        <!-- Top gradient for badge readability -->
                        <Border VerticalAlignment="Top" Height="52" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#66000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Top-Left: airing + rewatching pills -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                    Margin="8" Orientation="Horizontal" Spacing="4">
                            <Border Classes="Badge" Background="{Binding Presentation.AiringBadgeColor}"
                                    IsVisible="{Binding Presentation.AiringBadgeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Presentation.AiringBadgeText}"
                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Border Classes="Badge" Background="#2E7D32"
                                    IsVisible="{Binding IsRewatching}">
                                <TextBlock Text="{DynamicResource l.anime.status.rewatching}"
                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <!-- Top-Right: clickable score -->
                        <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="8" Padding="2" Background="Transparent"
                                BorderThickness="0" CornerRadius="6"
                                Command="{Binding #animeListRoot.((vm:AnimeListViewModel)DataContext).OpenScoreMenuCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding Score, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="4" Color="#AA000000" OffsetX="0" OffsetY="1"/>
                            </Button.Effect>
                            <Button.Flyout>
                                <MenuFlyout ItemsSource="{Binding $parent[UserControl].DataContext.AvailableScores}"
                                            FlyoutPresenterClasses="ScoreFlyout"
                                            Opened="ScoreMenu_Opened"/>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <material:MaterialIcon Kind="Star" Width="13" Height="13" Foreground="#f1c40f" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Score}" FontSize="11" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Panel>

                    <!-- Bottom Info -->
                    <StackPanel Grid.Row="1" Margin="11,10,11,12" Spacing="8">
                        <StackPanel Spacing="2" Height="36" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                       MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="15" Foreground="{DynamicResource SystemBaseHighColor}"/>
                            <TextBlock Text="{Binding RussianTitle}" FontSize="10"
                                       MaxLines="1" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="13" Foreground="{DynamicResource SystemBaseMediumColor}" Opacity="0.85"
                                       IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>

                        <!-- Progress bar -->
                        <controls:SegmentedProgressBar Margin="0,4,0,4"
                                                       Current="{Binding Progress}"
                                                       Total="{Binding Presentation.EffectiveTotal}"
                                                       Aired="{Binding Presentation.ResolvedAiredEpisodes}"
                                                       AccentBrush="#67D7A1"
                                                       AiredBrush="#E53935"
                                                       TrackBrush="{DynamicResource SegmentedTrackBrush}"
                                                       IsVisible="{Binding Presentation.ShowProgress}"/>

                        <!-- Episode controls -->
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Button Grid.Column="0" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.DecrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Minus" Width="16" Height="16" Foreground="{DynamicResource SystemBaseMediumColor}"/>
                            </Button>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Presentation.ProgressPart}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource SystemBaseMediumColor}" IsVisible="{Binding Presentation.ShowProgress}"/>
                                <TextBlock Text="{Binding Presentation.TotalPart}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource SystemBaseMediumColor}"/>
                            </StackPanel>

                            <Button Grid.Column="2" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.IncrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Plus" Width="16" Height="16" Foreground="#67D7A1"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
                </Border>
            </Border>
        </DataTemplate>

        <!-- ═══════════ VARIANT C: Wide Horizontal ═══════════ -->
        <DataTemplate x:Key="CardTemplateWide" x:DataType="models:AnimeItem">
            <Border Classes="AnimeCard revealItem" Margin="4" ClipToBounds="True" Height="128">
                <Grid ColumnDefinitions="90, *">
                    <!-- Left: Poster -->
                    <Panel Grid.Column="0" Background="Transparent" DoubleTapped="Poster_DoubleTapped"
                           ClipToBounds="True">
                        <Image core:CachedImage.Source="{Binding MainPictureUrl}" Stretch="UniformToFill"/>
                        <!-- Badges on poster -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                    Margin="5" Orientation="Vertical" Spacing="3">
                            <Border Classes="Badge" Background="{Binding Presentation.AiringBadgeColor}"
                                    IsVisible="{Binding Presentation.AiringBadgeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Presentation.AiringBadgeText}"
                                           FontSize="8" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Border Classes="Badge" Background="#2E7D32"
                                    IsVisible="{Binding IsRewatching}">
                                <TextBlock Text="{DynamicResource l.anime.status.rewatching}"
                                           FontSize="8" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Panel>

                    <!-- Right: Info -->
                    <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *, Auto, Auto" Margin="12,10,10,8">
                        <!-- Title + Score -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                       MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="17"
                                       Foreground="{DynamicResource SystemBaseHighColor}"/>
                            <!-- Score badge -->
                            <Button Grid.Column="1" Padding="2" Background="Transparent"
                                    BorderThickness="0" CornerRadius="6" Margin="6,0,0,0"
                                    VerticalAlignment="Top"
                                    Command="{Binding #animeListRoot.((vm:AnimeListViewModel)DataContext).OpenScoreMenuCommand}"
                                    CommandParameter="{Binding}"
                                    IsVisible="{Binding Score, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <Button.Flyout>
                                    <MenuFlyout ItemsSource="{Binding $parent[UserControl].DataContext.AvailableScores}"
                                                FlyoutPresenterClasses="ScoreFlyout"
                                                Opened="ScoreMenu_Opened"/>
                                </Button.Flyout>
                                <StackPanel Orientation="Horizontal" Spacing="3">
                                    <material:MaterialIcon Kind="Star" Width="12" Height="12" Foreground="#f1c40f" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Score}" FontSize="11" Foreground="{DynamicResource SystemBaseHighColor}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Russian title -->
                        <TextBlock Grid.Row="1" Text="{Binding RussianTitle}" FontSize="10"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"
                                   LineHeight="14" Margin="0,2,0,0"
                                   Foreground="{DynamicResource SystemAccentColor}" Opacity="0.8"
                                   IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- Spacer row 2 -->

                        <!-- Progress bar -->
                        <Border Grid.Row="3" Height="4" Margin="0,0,0,6"
                                Background="{DynamicResource SubtleFillColorTertiary}"
                                CornerRadius="2" ClipToBounds="True"
                                UseLayoutRounding="True">
                            <Panel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Border Background="#E53935"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        CornerRadius="2" RenderTransformOrigin="0%,0%"
                                        IsVisible="{Binding Presentation.ShowAiredProgressBar}">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="{Binding Presentation.AiredValueFraction}"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Border Background="{DynamicResource SystemAccentColor}"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        CornerRadius="2" RenderTransformOrigin="0%,0%">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="{Binding Presentation.ProgressValueFraction}"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Panel>
                        </Border>

                        <!-- Controls row -->
                        <Grid Grid.Row="4" ColumnDefinitions="Auto, Auto, *, Auto" VerticalAlignment="Center">
                            <Button Grid.Column="0" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.DecrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Minus" Width="14" Height="14" Opacity="0.75"/>
                            </Button>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center" Margin="4,0">
                                <TextBlock Text="{Binding Presentation.ProgressPart}" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemBaseHighColor}"
                                           IsVisible="{Binding Presentation.ShowProgress}"/>
                                <TextBlock Text="{Binding Presentation.TotalPart}" FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemBaseMediumColor}"/>
                            </StackPanel>
                            <Button Grid.Column="3" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.IncrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Plus" Width="14" Height="14"
                                                      Foreground="{DynamicResource SystemAccentColor}"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══════════ VARIANT D: Minimal Poster ═══════════ -->
        <DataTemplate x:Key="CardTemplateMinimal" x:DataType="models:AnimeItem">
            <Border Classes="AnimeCard revealItem MinimalCard" Margin="4" Width="155" Height="220" ClipToBounds="True"
                    CornerRadius="12">
                <Panel Background="Transparent" DoubleTapped="Poster_DoubleTapped">
                    <Image core:CachedImage.Source="{Binding MainPictureUrl}" Stretch="UniformToFill"/>

                    <!-- Top gradient for badges -->
                    <Border VerticalAlignment="Top" Height="48" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="#55000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Top-Left: airing pills (always visible) -->
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                Margin="8" Orientation="Horizontal" Spacing="4">
                        <Border Classes="Badge" Background="{Binding Presentation.AiringBadgeColor}"
                                IsVisible="{Binding Presentation.AiringBadgeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding Presentation.AiringBadgeText}"
                                       FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <Border Classes="Badge" Background="#2E7D32"
                                IsVisible="{Binding IsRewatching}">
                            <TextBlock Text="{DynamicResource l.anime.status.rewatching}"
                                       FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Top-Right: score (always visible) -->
                    <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="8" Padding="2" Background="Transparent"
                            BorderThickness="0" CornerRadius="6"
                            Command="{Binding #animeListRoot.((vm:AnimeListViewModel)DataContext).OpenScoreMenuCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding Score, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="4" Color="#AA000000" OffsetX="0" OffsetY="1"/>
                        </Button.Effect>
                        <Button.Flyout>
                            <MenuFlyout ItemsSource="{Binding $parent[UserControl].DataContext.AvailableScores}"
                                        FlyoutPresenterClasses="ScoreFlyout"
                                        Opened="ScoreMenu_Opened"/>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <material:MaterialIcon Kind="Star" Width="13" Height="13" Foreground="#f1c40f" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Score}" FontSize="11" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Hover overlay: slide-up from bottom -->
                    <Border Classes="MinimalOverlay" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.25"/>
                                <GradientStop Color="#BB000000" Offset="0.6"/>
                                <GradientStop Color="#EE000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,8" Spacing="2">
                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                       MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="15" Foreground="White"/>
                            <TextBlock Text="{Binding RussianTitle}" FontSize="9"
                                       MaxLines="1" TextTrimming="CharacterEllipsis"
                                       Foreground="#A0FFFFFF"
                                       IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                            <!-- Thin progress bar -->
                            <Border Height="3" Margin="0,4,0,2"
                                    Background="#20FFFFFF"
                                    CornerRadius="1.5" ClipToBounds="True">
                                <Panel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Border Background="#E53935"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="1.5" RenderTransformOrigin="0%,0%"
                                            IsVisible="{Binding Presentation.ShowAiredProgressBar}">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="{Binding Presentation.AiredValueFraction}"/>
                                        </Border.RenderTransform>
                                    </Border>
                                    <Border Background="{DynamicResource SystemAccentColor}"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="1.5" RenderTransformOrigin="0%,0%">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="{Binding Presentation.ProgressValueFraction}"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Panel>
                            </Border>

                            <!-- Progress text -->
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Presentation.ProgressPart}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" IsVisible="{Binding Presentation.ShowProgress}"/>
                                <TextBlock Text="{Binding Presentation.TotalPart}" FontSize="11" Foreground="#70FFFFFF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Panel>
            </Border>
        </DataTemplate>

        <!-- ═══════════ VARIANT: Poster First ═══════════ -->
        <DataTemplate x:Key="CardTemplatePosterFirst" x:DataType="models:AnimeItem">
            <Border Classes="AnimeCard revealItem PosterFirstCard" Margin="4" Width="164" Height="318"
                    CornerRadius="14" ClipToBounds="True"
                    BorderBrush="{DynamicResource DividerStrokeColorDefault}" BorderThickness="1">
                <Grid RowDefinitions="195,*">

                    <!-- ══ Poster panel ══ -->
                    <Panel Grid.Row="0" DoubleTapped="Poster_DoubleTapped">
                        <TemplatedControl Template="{DynamicResource PosterLoadingTemplate}"/>
                        <Image core:CachedImage.Source="{Binding MainPictureUrl}" Stretch="UniformToFill"/>

                        <!-- Airing + rewatching badges (top-left) -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                    Margin="9" Orientation="Horizontal" Spacing="4">
                            <Border Classes="Badge" Background="{Binding Presentation.AiringBadgeColor}"
                                    IsVisible="{Binding Presentation.AiringBadgeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Presentation.AiringBadgeText}"
                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Border Classes="Badge" Background="#2E7D32"
                                    IsVisible="{Binding IsRewatching}">
                                <TextBlock Text="{DynamicResource l.anime.status.rewatching}"
                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <!-- Score badge (top-right) -->
                        <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="9" Padding="2" Background="Transparent"
                                BorderThickness="0" CornerRadius="6"
                                Command="{Binding #animeListRoot.((vm:AnimeListViewModel)DataContext).OpenScoreMenuCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding Score, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="4" Color="#AA000000" OffsetX="0" OffsetY="1"/>
                            </Button.Effect>
                            <Button.Flyout>
                                <MenuFlyout ItemsSource="{Binding $parent[UserControl].DataContext.AvailableScores}"
                                            FlyoutPresenterClasses="ScoreFlyout"
                                            Opened="ScoreMenu_Opened"/>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <material:MaterialIcon Kind="Star" Width="11" Height="11" Foreground="#FFD700" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Score}" FontSize="10" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Panel>

                    <!-- ══ Info panel ══ -->
                    <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto" Margin="12,10,12,4">

                        <!-- Title block: English + Russian, 2 lines each -->
                        <StackPanel Grid.Row="0" Spacing="2" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13" FontWeight="Bold" MaxLines="2"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="16"
                                       Foreground="{DynamicResource SystemBaseHighColor}"/>
                            <TextBlock Text="{Binding RussianTitle}"
                                       FontSize="10" MaxLines="2"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       LineHeight="14"
                                       Foreground="{DynamicResource SystemBaseMediumColor}" Opacity="0.85"
                                       IsVisible="{Binding RussianTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>

                        <!-- Segmented progress dots -->
                        <controls:SegmentedProgressBar Grid.Row="1"
                                                       Margin="0,0,0,4"
                                                       Current="{Binding Progress}"
                                                       Total="{Binding Presentation.EffectiveTotal}"
                                                       Aired="{Binding Presentation.ResolvedAiredEpisodes}"
                                                       AccentBrush="#3DBA6F"
                                                       AiredBrush="#E53935"
                                                       TrackBrush="{DynamicResource SegmentedTrackBrush}"
                                                       IsVisible="{Binding Presentation.ShowProgress}"/>

                        <!-- Episode controls row -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Button Grid.Column="0" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.DecrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Minus" Width="16" Height="16" Foreground="{DynamicResource SystemBaseMediumColor}"/>
                            </Button>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Presentation.ProgressPart}" FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource SystemBaseMediumColor}"
                                           IsVisible="{Binding Presentation.ShowProgress}"/>
                                <TextBlock Text="{Binding Presentation.TotalPart}" FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource SystemBaseMediumColor}"/>
                            </StackPanel>

                            <Button Grid.Column="2" Classes="ProgressStep"
                                    IsVisible="{Binding Presentation.CanEditProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.IncrementProgressCommand}"
                                    CommandParameter="{Binding}">
                                <material:MaterialIcon Kind="Plus" Width="16" Height="16" Foreground="#3DBA6F"/>
                            </Button>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="MenuFlyoutPresenter.ScoreFlyout MenuItem" x:DataType="models:RatingOption">
                    <Setter Property="Header" Value="{Binding Display}"/>
                    <Setter Property="Command" Value="{Binding #animeListRoot.((vm:AnimeListViewModel)DataContext).ApplyScoreFromMenuCommand}"/>
                    <Setter Property="CommandParameter" Value="{Binding}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ScoreFlyoutItemForeground}"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.12"/>
                        </Transitions>
                    </Setter>
                </Style>

        <StyleInclude Source="avares://Kiriha/Views/Styles/AnimeListViewStyles.axaml"/>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="0">

        <!-- Search Bar + Sorting + Filters + Sync -->
        <Border Grid.Row="0" Margin="20,4,20,12" Padding="8,6" Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="10"
                BorderBrush="{DynamicResource CardStrokeColorDefault}" BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <!-- Search -->
                <TextBox Grid.Column="0" PlaceholderText="{DynamicResource l.common.actions.search}"
                         Text="{Binding SearchQuery}"
                         VerticalAlignment="Center" Height="34"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center"
                         FontSize="13" Padding="8,0">
                    <TextBox.InnerRightContent>
                        <material:MaterialIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Opacity="0.3"/>
                    </TextBox.InnerRightContent>
                </TextBox>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0">
                    <Button x:Name="ReleaseMapButton"
                            Background="Transparent" BorderThickness="0" Padding="8,6" CornerRadius="6"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center" Click="ReleaseMapButton_Click"
                            ToolTip.Tip="Расписание релизов">
                        <Button.Styles>
                            <Style Selector="Button.active /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                            </Style>
                            <Style Selector="Button.active TextBlock">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                            <Style Selector="Button.active material|MaterialIcon">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                        </Button.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <material:MaterialIcon Kind="CalendarClock" Width="16" Height="16" Opacity="0.62"
                                                   VerticalAlignment="Center"/>
                            <TextBlock Text="Расписание" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource DividerStrokeColorDefault}" Margin="4,0"/>

                    <!-- Sort -->
                    <Button Background="Transparent" BorderThickness="0" Padding="8,6" CornerRadius="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <material:MaterialIcon Kind="SortVariant" Width="16" Height="16" Opacity="0.6"/>
                            <TextBlock Text="{Binding DisplaySortBy}" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight" FlyoutPresenterClasses="FilterFlyout">
                                <ListBox Classes="SortList" Margin="6"
                                         ItemsSource="{Binding SortOptions}"
                                         SelectedItem="{Binding SortBy}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid ColumnDefinitions="14,*" VerticalAlignment="Center">
                                                <material:MaterialIcon Grid.Column="0" Kind="Check" Width="13" Height="13"
                                                                      VerticalAlignment="Center"
                                                                      Foreground="{DynamicResource SystemAccentColor}"
                                                                      IsVisible="{Binding $parent[ListBoxItem].IsSelected}"/>
                                                <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                           Text="{Binding Converter={StaticResource LocConverter}}"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Filters -->
                    <Button Classes.active="{Binding IsFilterActive}" Background="Transparent" VerticalAlignment="Center"
                            BorderThickness="0" Padding="8,6" CornerRadius="6">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Style>
                            <Style Selector="Button.active">
                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                            <Style Selector="Button.active TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </Button.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <material:MaterialIcon Kind="FilterVariant" Width="16" Height="16"
                                                  Foreground="{Binding $parent[Button].Foreground}"/>
                            <TextBlock Text="{DynamicResource l.filters.title}" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{Binding $parent[Button].Foreground}"/>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight" FlyoutPresenterClasses="FilterFlyout">
                                <StackPanel Spacing="6" Margin="10">
                                            <!-- NSFW toggle row -->
                                            <ToggleButton Classes="FilterToggle" IsChecked="{Binding FilterNsfw}">
                                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                        Background="#1FF44336" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <material:MaterialIcon Kind="AlertOctagonOutline" Width="13" Height="13"
                                                                          Foreground="#FFF44336"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource l.filters.visibility.adult_only}"
                                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Border Grid.Column="2" Classes="SwitchTrack" VerticalAlignment="Center">
                                                    <Ellipse Classes="SwitchThumb"/>
                                                </Border>
                                            </Grid>
                                            </ToggleButton>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!-- Sync -->
                <Button Grid.Column="2" Command="{Binding SyncMalCommand}"
                        Padding="12,0" Height="34"
                        CornerRadius="8" FontSize="12" FontWeight="SemiBold"
                        Background="{DynamicResource SystemAccentColor}" Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <material:MaterialIcon Kind="Sync" Width="16" Height="16"/>
                        <TextBlock Text="{DynamicResource l.sync.actions.sync_now}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Status Tabs -->
        <Border x:Name="StatusTabsPanel"
                Grid.Row="1" Margin="20,0,20,12" Padding="4"
                Background="{DynamicResource SubtleFillColorSecondary}" CornerRadius="8"
                HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <RadioButton Content="{Binding WatchingHeader}" Command="{Binding FilterCommand}" CommandParameter="Watching"
                             IsChecked="{Binding IsWatchingSelected, Mode=OneWay}" Classes="Pill" GroupName="StatusFilter"/>
                <RadioButton Content="{Binding CompletedHeader}" Command="{Binding FilterCommand}" CommandParameter="Completed"
                             IsChecked="{Binding IsCompletedSelected, Mode=OneWay}" Classes="Pill" GroupName="StatusFilter"/>
                <RadioButton Content="{Binding OnHoldHeader}" Command="{Binding FilterCommand}" CommandParameter="OnHold"
                             IsChecked="{Binding IsOnHoldSelected, Mode=OneWay}" Classes="Pill" GroupName="StatusFilter"/>
                <RadioButton Content="{Binding DroppedHeader}" Command="{Binding FilterCommand}" CommandParameter="Dropped"
                             IsChecked="{Binding IsDroppedSelected, Mode=OneWay}" Classes="Pill" GroupName="StatusFilter"/>
                <RadioButton Content="{Binding PlanToWatchHeader}" Command="{Binding FilterCommand}" CommandParameter="PlanToWatch"
                             IsChecked="{Binding IsPlanToWatchSelected, Mode=OneWay}" Classes="Pill" GroupName="StatusFilter"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT: Grid ═══ -->
        <ScrollViewer x:Name="AnimeListScrollViewer"
                      Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      u:SmoothScroll.IsEnabled="True">
            <ItemsRepeater x:Name="AnimeGridRepeater"
                           ItemsSource="{Binding FilteredItems}"
                           Margin="20,0,20,16"
                           ItemTemplate="{StaticResource CardTemplateCinematic}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="163"
                                          MinItemHeight="275"
                                          MinColumnSpacing="0"
                                          MinRowSpacing="0"
                                          ItemsJustification="Start"/>
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
        </ScrollViewer>

        <Border x:Name="ReleaseMapOverlay"
                Grid.Row="1"
                Grid.RowSpan="2"
                Margin="20,0,20,16"
                Padding="0"
                Background="{DynamicResource CardBackgroundFillDefault}"
                BorderBrush="{DynamicResource CardStrokeColorDefault}"
                BorderThickness="1"
                CornerRadius="16"
                ClipToBounds="True"
                Focusable="True"
                IsVisible="False"
                BoxShadow="0 2 8 0 #18000000"
                Opacity="1"
                RenderTransform="translate(0,0)"
                KeyDown="ReleaseMapOverlay_KeyDown">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <Grid RowDefinitions="Auto,*">

                <!-- HERO BANNER -->
                <Border x:Name="ReleaseHeaderPanel"
                        Grid.Row="0"
                        Height="150"
                        CornerRadius="16,16,0,0"
                        ClipToBounds="True"
                        Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="{DynamicResource SystemAccentColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource SystemAccentColorDark1}" Offset="0.62"/>
                            <GradientStop Color="{DynamicResource SystemAccentColorDark2}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Panel>
                        <!-- Details-style hero: poster as object, not background. -->
                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">

                            <Border Grid.Column="0"
                                    Width="100"
                                    Height="118"
                                    CornerRadius="8"
                                    ClipToBounds="True"
                                    BoxShadow="0 4 20 0 #60000000">
                                <Image x:Name="ReleaseHeroPoster"
                                       Stretch="UniformToFill"
                                       IsHitTestVisible="False"/>
                            </Border>

                            <!-- LEFT: title, meta, summary -->
                            <StackPanel Grid.Column="1" Margin="18,0,62,0" VerticalAlignment="Center" Spacing="3">

                                <!-- Main anime title -->
                                <TextBlock x:Name="ReleaseHeroAnimeTitle"
                                           Text=""
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="White"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"
                                           LineHeight="28"/>
 
                                <TextBlock x:Name="ReleaseHeroRussianTitle"
                                           Text=""
                                           FontSize="12"
                                           Foreground="#A8FFFFFF"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="False"/>

                                <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,6,0,0">
                                    <Border Padding="8,4" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock x:Name="ReleaseHeroKindText"
                                                   Text="Следующая серия"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E6FFFFFF"/>
                                    </Border>

                                    <Border Padding="8,4" CornerRadius="6" Background="#16FFFFFF">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <material:MaterialIcon Kind="ClockOutline" Width="13" Height="13"
                                                                   Foreground="#CCFFFFFF"
                                                                   VerticalAlignment="Center"/>
                                            <TextBlock x:Name="ReleaseHeroCountdownText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="#D8FFFFFF"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="8,4" CornerRadius="6" Background="#16FFFFFF">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <material:MaterialIcon Kind="CalendarClock" Width="13" Height="13"
                                                                   Foreground="#CCFFFFFF"
                                                                   VerticalAlignment="Center"/>
                                            <TextBlock x:Name="ReleaseHeroTimeText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="#D8FFFFFF"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="ReleaseHeroWeekText"
                                           Text=""
                                           FontSize="11"
                                           Foreground="#80FFFFFF"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- RIGHT: close button anchored top-right -->
                            <Button Grid.Column="1"
                                    Width="30" Height="30"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    Background="#30FFFFFF"
                                    BorderThickness="0"
                                    CornerRadius="15"
                                    Click="ReleaseCloseButton_Click"
                                    ToolTip.Tip="Закрыть  Esc · F12">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#55FFFFFF"/>
                                    </Style>
                                </Button.Styles>
                                <material:MaterialIcon Kind="Close" Width="15" Height="15" Foreground="White"/>
                            </Button>
                        </Grid>
                    </Panel>
                </Border>

                <!-- CARD LIST -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,14">
                        <StackPanel x:Name="ReleaseTimelinePanel" Spacing="3"/>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <Border x:Name="ReleaseEmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="40,32"
                            IsVisible="False">
                        <StackPanel Spacing="14" HorizontalAlignment="Center">
                            <material:MaterialIcon Kind="CalendarBlankOutline" Width="48" Height="48"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#30FFFFFF"/>
                            <TextBlock Text="Нет предстоящих релизов"
                                       FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="#80FFFFFF"/>
                            <TextBlock Text="После синхронизации здесь появится дорожная карта серий"
                                       Width="320" TextWrapping="Wrap" TextAlignment="Center"
                                       FontSize="12" Foreground="#40FFFFFF"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
